---
import TrialCard from './TrialCard.astro';

interface Props {
  lang?: 'en' | 'es';
  initialLocation?: string;
}

const { lang = "en", initialLocation = "" } = Astro.props;
---

<section id="trials" class="section-padding bg-slate-50/40" data-initial-location={initialLocation}>
  <div class="container mx-auto px-4">

    <!-- Header -->
    <div class="max-w-3xl mx-auto text-center mb-12 animate-fade-in">
      <div class="inline-flex items-center gap-3 px-4 py-2 rounded-full bg-accent/5 border border-accent/10 text-accent text-[10px] font-black uppercase tracking-[0.2em] mb-6">
        <span class="w-1.5 h-1.5 rounded-full bg-accent animate-pulse"></span>
        {lang === 'en' ? 'Now Recruiting' : 'Reclutando Ahora'}
      </div>
      <h2 class="text-4xl md:text-6xl font-black mb-4 tracking-tighter text-primary">
        {lang === 'en' ? 'Weight Loss' : 'Ensayos de'} <span class="text-gradient leading-tight">{lang === 'en' ? 'Trials.' : 'Pérdida de Peso.'}</span>
      </h2>
      <p class="text-slate-500 text-lg font-medium leading-relaxed max-w-2xl mx-auto">
        {lang === 'en'
          ? 'Every study below offers free access to cutting-edge treatments. Many pay up to $1,500. No insurance needed.'
          : 'Cada estudio ofrece acceso gratuito a tratamientos de vanguardia. Muchos pagan hasta $1,500. Sin seguro médico.'}
      </p>
    </div>

    <!-- Filter Bar -->
    <div class="max-w-5xl mx-auto mb-10">
      <div class="bg-white rounded-3xl p-5 shadow-lg shadow-slate-200/50 border border-slate-100">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-3">
          <!-- Search -->
          <div class="relative">
            <input
              type="text"
              id="search-input"
              placeholder={lang === 'en' ? 'Search (Ozempic, GLP-1…)' : 'Buscar (Ozempic, GLP-1…)'}
              class="w-full px-5 py-3.5 rounded-2xl bg-slate-50 border border-slate-200 text-slate-700 placeholder-slate-400 focus:outline-none focus:border-accent focus:ring-2 focus:ring-accent/10 transition-all text-sm"
            />
            <svg class="absolute right-4 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
            </svg>
          </div>
          <!-- Location -->
          <select id="location-filter" class="w-full px-5 py-3.5 rounded-2xl bg-slate-50 border border-slate-200 text-slate-700 focus:outline-none focus:border-accent focus:ring-2 focus:ring-accent/10 transition-all appearance-none cursor-pointer text-sm">
            <option value="">{lang === 'en' ? 'All Cities' : 'Todas las Ciudades'}</option>
            <option value="New York, NY" selected={initialLocation === 'New York City'}>🗽 NYC</option>
            <option value="Miami, FL" selected={initialLocation === 'Miami'}>🌴 Miami</option>
            <option value="Houston, TX" selected={initialLocation === 'Houston'}>🚀 Houston</option>
            <option value="Los Angeles, CA" selected={initialLocation === 'Los Angeles'}>🌆 Los Angeles</option>
            <option value="San Francisco, CA" selected={initialLocation === 'San Francisco'}>🌉 San Francisco</option>
          </select>
          <!-- Phase -->
          <select id="phase-filter" class="w-full px-5 py-3.5 rounded-2xl bg-slate-50 border border-slate-200 text-slate-700 focus:outline-none focus:border-accent focus:ring-2 focus:ring-accent/10 transition-all appearance-none cursor-pointer text-sm">
            <option value="">{lang === 'en' ? 'All Phases' : 'Todas las Fases'}</option>
            <option value="PHASE3">{lang === 'en' ? 'Phase 3 – Near Approval' : 'Fase 3 – Casi aprobado'}</option>
            <option value="PHASE2">{lang === 'en' ? 'Phase 2 – Efficacy' : 'Fase 2 – Eficacia'}</option>
            <option value="PHASE1">{lang === 'en' ? 'Phase 1 – Safety' : 'Fase 1 – Seguridad'}</option>
          </select>
          <!-- Compensation -->
          <select id="compensation-filter" class="w-full px-5 py-3.5 rounded-2xl bg-slate-50 border border-slate-200 text-slate-700 focus:outline-none focus:border-accent focus:ring-2 focus:ring-accent/10 transition-all appearance-none cursor-pointer text-sm">
            <option value="">{lang === 'en' ? 'All Studies' : 'Todos'}</option>
            <option value="true">{lang === 'en' ? '💰 Paid Studies Only' : '💰 Solo estudios pagados'}</option>
            <option value="false">{lang === 'en' ? 'No Payment' : 'Sin pago'}</option>
          </select>
        </div>
        <!-- Stats bar -->
        <div class="flex flex-wrap gap-4 mt-4 pt-4 border-t border-slate-100" id="stats-bar">
          <span class="text-xs text-slate-400 font-medium">{lang === 'en' ? 'Loading trials…' : 'Cargando ensayos…'}</span>
        </div>
      </div>
    </div>

    <!-- Results Area -->
    <div id="trials-container" class="min-h-[400px]">
      <!-- Loading Skeletons -->
      <div id="loading-state" class="hidden">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
          {[1,2,3].map(() => (
            <div class="bg-white border border-slate-100 rounded-[2.5rem] p-8 animate-pulse">
              <div class="flex gap-2 mb-6"><div class="h-5 w-20 bg-slate-200 rounded-full"></div><div class="h-5 w-16 bg-slate-100 rounded-full"></div></div>
              <div class="h-7 bg-slate-200 rounded-xl w-3/4 mb-3"></div>
              <div class="h-4 bg-slate-100 rounded w-full mb-2"></div>
              <div class="h-4 bg-slate-100 rounded w-5/6 mb-8"></div>
              <div class="space-y-3 mt-auto">
                <div class="h-12 bg-slate-100 rounded-2xl"></div>
                <div class="h-12 bg-slate-100 rounded-2xl"></div>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Trials Grid -->
      <div id="trials-grid" class="grid grid-cols-1 lg:grid-cols-3 gap-8"></div>

      <!-- Empty State -->
      <div id="empty-state" class="hidden text-center py-20">
        <div class="w-20 h-20 bg-slate-100 rounded-full flex items-center justify-center mx-auto mb-5">
          <svg class="w-10 h-10 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
        </div>
        <h3 class="text-xl font-bold text-slate-700 mb-2">{lang === 'en' ? 'No trials found' : 'No se encontraron ensayos'}</h3>
        <p class="text-slate-500 text-sm">{lang === 'en' ? 'Try adjusting your filters' : 'Intenta ajustar los filtros'}</p>
      </div>
    </div>

    <!-- Pagination -->
    <div id="pagination" class="hidden mt-12 flex justify-center items-center gap-4">
      <button id="prev-page" class="px-6 py-3 rounded-xl bg-white border border-slate-200 text-slate-600 font-medium hover:border-accent hover:text-accent transition-all disabled:opacity-40 text-sm">
        ← {lang === 'en' ? 'Previous' : 'Anterior'}
      </button>
      <span id="page-info" class="text-slate-600 font-medium text-sm"></span>
      <button id="next-page" class="px-6 py-3 rounded-xl bg-white border border-slate-200 text-slate-600 font-medium hover:border-accent hover:text-accent transition-all disabled:opacity-40 text-sm">
        {lang === 'en' ? 'Next' : 'Siguiente'} →
      </button>
    </div>

  </div>
</section>

<script>
  import { TrialsService } from '../lib/services/trials.service';

  class TrialsManager {
    constructor(lang) {
      this.lang = lang;
      this.currentPage = 1;
      
      // Get initial location from data attribute
      const trialsSection = document.getElementById('trials');
      const initialLoc = trialsSection?.dataset.initialLocation || '';
      
      // Map display name back to select value if needed
      const locFilter = document.getElementById('location-filter') as HTMLSelectElement;
      
      this.currentFilters = {
        location: locFilter?.value || initialLoc || undefined
      };
      
      this.totalPages = 1;
      
      // DOM Elements
      this.grid = document.getElementById('trials-grid');
      this.loading = document.getElementById('loading-state');
      this.empty = document.getElementById('empty-state');
      this.pagination = document.getElementById('pagination');
      this.pageInfo = document.getElementById('page-info');
      this.stats = document.getElementById('stats-bar');
      
      this.initEvents();
      this.load();
    }

    initEvents() {
      const search = document.getElementById('search-input');
      const location = document.getElementById('location-filter');
      const phase = document.getElementById('phase-filter');
      const compensation = document.getElementById('compensation-filter');
      const prev = document.getElementById('prev-page');
      const next = document.getElementById('next-page');

      const handler = () => {
        this.currentFilters = {
          q: search.value,
          location: location.value,
          phase: phase.value,
          compensation: compensation.value || undefined
        };
        this.currentPage = 1;
        this.load();
      };

      const debounce = (fn, ms) => {
        let t; return (...a) => { clearTimeout(t); t = setTimeout(() => fn(...a), ms); };
      };

      search?.addEventListener('input', debounce(handler, 300));
      location?.addEventListener('change', handler);
      phase?.addEventListener('change', handler);
      compensation?.addEventListener('change', handler);

      prev?.addEventListener('click', () => { if (this.currentPage > 1) { this.currentPage--; this.load(); }});
      next?.addEventListener('click', () => { if (this.currentPage < this.totalPages) { this.currentPage++; this.load(); }});
    }

    async load() {
      this.setState('loading');
      
      try {
        const data = await TrialsService.getTrials({
          ...this.currentFilters,
          page: this.currentPage
        });

        if (data.trials && data.trials.length > 0) {
          this.totalPages = data.totalPages;
          this.render(data);
          this.setState('results');
        } else {
          this.setState('empty');
        }
      } catch (error) {
        console.error('Error loading trials:', error);
        this.setState('empty');
      }
    }

    setState(state) {
      this.loading.classList.toggle('hidden', state !== 'loading');
      this.grid.classList.toggle('hidden', state !== 'results');
      this.empty.classList.toggle('hidden', state !== 'empty');
      this.pagination.classList.toggle('hidden', state !== 'results' || this.totalPages <= 1);
    }

    render(data) {
      this.grid.innerHTML = data.trials.map(trial => this.getCardTemplate(trial)).join('');
      
      this.pageInfo.textContent = `${this.lang === 'en' ? 'Page' : 'Página'} ${data.page} / ${data.totalPages}`;
      document.getElementById('prev-page').disabled = data.page <= 1;
      document.getElementById('next-page').disabled = data.page >= data.totalPages;

      this.stats.innerHTML = `
        <span class="text-xs font-medium text-slate-500">
          ${this.lang === 'en'
            ? `Showing <strong>${data.trials.length}</strong> of <strong>${data.total}</strong> active weight loss trials`
            : `Mostrando <strong>${data.trials.length}</strong> de <strong>${data.total}</strong> ensayos activos`}
        </span>
      `;
    }

    getCardTemplate(trial) {
      const isRecruiting = trial.overall_status === 'RECRUITING' || trial.status_label === 'Recruiting';
      const city = [trial.primary_location_city, trial.primary_location_state].filter(Boolean).join(', ') || 'Various Locations';
      const phaseMap = { PHASE3:'emerald', PHASE2:'blue', PHASE1:'amber', PHASE4:'teal', NA:'slate' };
      const phaseCol = phaseMap[trial.phase] || 'slate';
      
      return `
        <article class="group relative bg-white border border-slate-100 rounded-[2.5rem] overflow-hidden hover:border-accent/50 transition-all duration-500 hover:shadow-xl flex flex-col h-full">
          <div class="h-1 w-full bg-gradient-to-r from-transparent via-accent to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
          <div class="p-8 flex flex-col h-full gap-6">
            <div class="flex items-center justify-between">
              <span class="text-[10px] font-black uppercase tracking-widest px-4 py-2 rounded-full ${isRecruiting ? 'bg-accent text-white' : 'bg-slate-100 text-slate-500'}">
                ${isRecruiting ? (this.lang === 'en' ? 'Recruiting' : 'Reclutando') : 'Active'}
              </span>
              <span class="text-[10px] font-black uppercase tracking-widest text-${phaseCol}-600 bg-${phaseCol}-50 px-3 py-1.5 rounded-full border border-${phaseCol}-100">
                ${trial.phase_label || trial.phase}
              </span>
            </div>
            
            <div class="flex-1 space-y-3">
              <h3 class="text-xl font-black text-primary group-hover:text-accent transition-colors line-clamp-2">${trial.title}</h3>
              <p class="text-slate-500 text-sm line-clamp-3">${trial.ai_summary || trial.brief_summary}</p>
            </div>
            
            <div class="space-y-2.5">
              <div class="flex items-center gap-3 p-3 rounded-2xl bg-slate-50 border border-slate-100">
                <div class="text-accent">📍</div>
                <div class="text-[11px] font-black uppercase tracking-tighter text-slate-400 mr-auto">${this.lang === 'en' ? 'Location' : 'Ciudad'}</div>
                <div class="text-xs font-bold text-slate-700">${city}</div>
              </div>
              ${trial.has_compensation ? `
                <div class="flex items-center gap-3 p-3 rounded-2xl bg-emerald-50 border border-emerald-100">
                  <div class="text-emerald-500">💰</div>
                  <div class="text-[11px] font-black uppercase tracking-tighter text-emerald-600 mr-auto">${this.lang === 'en' ? 'Compensation' : 'Pago'}</div>
                  <div class="text-xs font-black text-emerald-700">${trial.compensation_amount || (this.lang === 'en' ? '$500+' : '$500+')}</div>
                </div>
              ` : ''}
            </div>

            <div class="flex gap-2 pt-2">
              <button onclick="openLeadModal('${trial.nct_id}', \`${trial.title.replace(/'/g, "")}\`)" class="flex-1 py-4 rounded-2xl bg-accent text-white font-black text-xs uppercase tracking-[0.2em] hover:bg-primary transition-all shadow-lg shadow-accent/20">
                 ${this.lang === 'en' ? '⚡ Apply' : '⚡ Aplicar'}
              </button>
              <a href="/trial/${trial.nct_id}" class="w-12 h-12 flex items-center justify-center rounded-2xl border border-slate-200 text-slate-400 hover:text-accent hover:border-accent transition-all">
                 <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                   <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
                 </svg>
              </a>
            </div>
          </div>
        </article>
      `;
    }
  }

  // Initialize
  const lang = document.documentElement.lang || 'en';
  new TrialsManager(lang);
</script>

<style>
  .line-clamp-2 { display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
  .line-clamp-3 { display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }
</style>
