---
const { lang = "en" } = Astro.props;

const steps = lang === 'en' ? [
  {
    n: '01',
    title: 'Browse Trials',
    desc: 'Search active weight-loss trials in NYC, Miami, Houston, LA, and San Francisco. Filter by compensation, phase, or medication.',
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>`,
  },
  {
    n: '02',
    title: 'Apply in 2 Minutes',
    desc: 'Fill out a short pre-screening form. We verify basic eligibility — no medical records needed at this stage.',
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>`,
  },
  {
    n: '03',
    title: 'We Call You',
    desc: 'Our concierge team calls you within 24 hours, confirms your eligibility over the phone, and books your screening visit.',
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 18 19.79 19.79 0 0 1 1.61 9.28 2 2 0 0 1 3.6 7h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91"/></svg>`,
  },
  {
    n: '04',
    title: 'Attend & Get Paid',
    desc: 'Show up to your free screening visit. If you qualify and enroll, you receive compensation — up to $1,500 — for your participation.',
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>`,
  },
] : [
  {
    n: '01',
    title: 'Busca ensayos',
    desc: 'Explora ensayos activos de pérdida de peso en NYC, Miami, Houston, LA y San Francisco.',
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>`,
  },
  {
    n: '02',
    title: 'Aplica en 2 minutos',
    desc: 'Completa un formulario corto de pre-cribado. Verificamos elegibilidad básica.',
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>`,
  },
  {
    n: '03',
    title: 'Te llamamos',
    desc: 'Nuestro equipo te llama en 24 horas, confirma tu elegibilidad y agenda tu visita de cribado.',
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 18 19.79 19.79 0 0 1 1.61 9.28 2 2 0 0 1 3.6 7h3a2 2 0 0 1 2 1.72"/></svg>`,
  },
  {
    n: '04',
    title: 'Asiste y cobra',
    desc: 'Asiste a tu visita gratuita de cribado. Si calificas y te inscribes, recibes hasta $1,500 de compensación.',
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>`,
  },
];
---

<section class="py-20 bg-slate-50 border-y border-slate-100">
  <div class="mx-auto w-full max-w-screen-xl px-4 md:px-8">

    <div class="text-center mb-14">
      <p class="text-[11px] font-black uppercase tracking-[0.25em] text-accent mb-3">
        {lang === 'en' ? 'Simple Process' : 'Proceso Simple'}
      </p>
      <h2 class="text-[2rem] md:text-[2.5rem] font-extrabold tracking-tight text-slate-900 mb-3">
        {lang === 'en' ? 'From application to payment' : 'De la solicitud al pago'}
      </h2>
      <p class="text-slate-500 font-semibold text-lg max-w-xl mx-auto">
        {lang === 'en'
          ? 'Our concierge team handles everything. You just show up.'
          : 'Nuestro equipo lo maneja todo. Tú solo aparece.'}
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      {steps.map((step, i) => (
        <div class="relative flex flex-col gap-4 rounded-2xl border border-slate-200 bg-white p-7 hover:border-accent/40 hover:shadow-lg transition-all duration-300 group">
          <!-- Step number watermark -->
          <div class="absolute top-5 right-6 text-5xl font-black text-slate-100 group-hover:text-accent/10 transition-colors select-none leading-none">{step.n}</div>
          <!-- Icon -->
          <div class="w-12 h-12 rounded-xl bg-accent/10 flex items-center justify-center text-accent" set:html={step.icon}></div>
          <!-- Content -->
          <div>
            <h3 class="text-lg font-extrabold text-slate-900 mb-2">{step.title}</h3>
            <p class="text-sm font-medium text-slate-500 leading-relaxed">{step.desc}</p>
          </div>
          <!-- Connector arrow (not on last) -->
          {i < steps.length - 1 && (
            <div class="hidden lg:block absolute -right-3.5 top-1/2 -translate-y-1/2 z-10">
              <div class="w-7 h-7 rounded-full bg-white border border-slate-200 flex items-center justify-center text-slate-300">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              </div>
            </div>
          )}
        </div>
      ))}
    </div>

    <!-- Values strip -->
    <div class="mt-12 grid grid-cols-1 md:grid-cols-3 gap-4">
      {[
        {
          title: lang === 'en' ? 'Unbiased Results' : 'Resultados Imparciales',
          sub: lang === 'en' ? 'We list every qualifying trial, not just sponsored ones.' : 'Listamos todos los ensayos que califican.',
          icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="2" x2="12" y2="6"/><line x1="12" y1="18" x2="12" y2="22"/><line x1="4.93" y1="4.93" x2="7.76" y2="7.76"/><line x1="16.24" y1="16.24" x2="19.07" y2="19.07"/><line x1="2" y1="12" x2="6" y2="12"/><line x1="18" y1="12" x2="22" y2="12"/><line x1="4.93" y1="19.07" x2="7.76" y2="16.24"/><line x1="16.24" y1="7.76" x2="19.07" y2="4.93"/></svg>`,
        },
        {
          title: lang === 'en' ? 'Your Data Stays Yours' : 'Tus Datos Son Tuyos',
          sub: lang === 'en' ? 'We only share your info with the trials you apply to.' : 'Solo compartimos tu info con los ensayos a los que aplicas.',
          icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
        },
        {
          title: lang === 'en' ? 'Verified Trials Only' : 'Solo Ensayos Verificados',
          sub: lang === 'en' ? 'All trials are from ClinicalTrials.gov, run by licensed doctors.' : 'Todos los ensayos provienen de ClinicalTrials.gov.',
          icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>`,
        },
      ].map(({ title, sub, icon }) => (
        <div class="flex items-start gap-4 p-6 rounded-2xl bg-[#002147] text-white">
          <div class="w-10 h-10 rounded-lg bg-white/10 flex items-center justify-center flex-shrink-0" set:html={icon}></div>
          <div>
            <div class="text-sm font-bold text-white mb-1">{title}</div>
            <div class="text-xs font-medium text-white/60 leading-relaxed">{sub}</div>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>
