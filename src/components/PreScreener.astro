---
const { trial, lang = "en" } = Astro.props;
import HIPAAAuthorization from './HIPAAAuthorization.astro';
---

<div class="bg-white rounded-[3rem] p-10 border border-slate-100 shadow-[0_40px_80px_-20px_rgba(0,0,0,0.08)] relative overflow-hidden group">
  <!-- Subtle aesthetic background -->
  <div class="absolute -top-24 -right-24 w-48 h-48 bg-accent/5 rounded-full blur-3xl group-hover:bg-accent/10 transition-all duration-1000"></div>
  
  <div class="max-w-2xl mx-auto relative z-10">
    <div class="text-center mb-10">
      <div class="inline-flex items-center gap-3 px-4 py-2 rounded-full bg-accent/5 border border-accent/10 text-accent text-[10px] font-black uppercase tracking-[0.3em] mb-6">
        <span class="w-1.5 h-1.5 rounded-full bg-accent animate-pulse"></span>
        {lang === 'en' ? 'Quick Application' : 'Solicitud Rápida'}
      </div>
      <h2 class="text-3xl md:text-4xl font-black text-primary mb-4 tracking-tighter">
        {lang === 'en' ? 'Apply for this Study' : 'Aplica a este Estudio'}
      </h2>
      <p class="text-slate-500 text-sm font-medium leading-relaxed">
        {lang === 'en'
          ? 'Enter your contact details. Our NYC medical team will review your request and call you within 24 hours.'
          : 'Ingresa tus datos de contacto. Nuestro equipo médico en NYC revisará tu solicitud y te llamará en 24 horas.'}
      </p>
    </div>

    <!-- Simple Form -->
    <form id="prescreen-form" class="space-y-6">
      <div class="space-y-4">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div class="space-y-2">
            <label class="text-[11px] font-black uppercase tracking-widest text-slate-400 ml-2">{lang === 'en' ? 'First Name' : 'Nombre'}</label>
            <input type="text" name="firstName" placeholder="John"
              class="w-full px-6 py-4 rounded-2xl bg-slate-50 border border-slate-100 text-primary font-bold placeholder:text-slate-300 focus:outline-none focus:ring-4 focus:ring-accent/10 focus:border-accent/40 transition-all" required>
          </div>
          <div class="space-y-2">
            <label class="text-[11px] font-black uppercase tracking-widest text-slate-400 ml-2">{lang === 'en' ? 'Last Name' : 'Apellido'}</label>
            <input type="text" name="lastName" placeholder="Doe"
              class="w-full px-6 py-4 rounded-2xl bg-slate-50 border border-slate-100 text-primary font-bold placeholder:text-slate-300 focus:outline-none focus:ring-4 focus:ring-accent/10 focus:border-accent/40 transition-all">
          </div>
        </div>

        <div class="space-y-2">
          <label class="text-[11px] font-black uppercase tracking-widest text-slate-400 ml-2">{lang === 'en' ? 'Phone Number' : 'Teléfono'}</label>
          <input type="tel" name="phone" placeholder="(555) 000-0000"
            class="w-full px-6 py-4 rounded-2xl bg-slate-50 border border-slate-100 text-primary font-bold placeholder:text-slate-300 focus:outline-none focus:ring-4 focus:ring-accent/10 focus:border-accent/40 transition-all" required>
        </div>

        <div class="space-y-2">
          <label class="text-[11px] font-black uppercase tracking-widest text-slate-400 ml-2">{lang === 'en' ? 'Email Address' : 'Correo Electrónico'}</label>
          <input type="email" name="email" placeholder="john@example.com"
            class="w-full px-6 py-4 rounded-2xl bg-slate-50 border border-slate-100 text-primary font-bold placeholder:text-slate-300 focus:outline-none focus:ring-4 focus:ring-accent/10 focus:border-accent/40 transition-all" required>
        </div>

        <div class="pt-4">
<label class="flex items-start gap-4 p-5 rounded-2xl bg-slate-50/50 border border-slate-100 cursor-pointer hover:bg-white transition-all">
  <input type="checkbox" id="consent" name="consent" class="peer sr-only" required>
  <div class="relative flex items-center justify-center w-6 h-6 rounded-lg border-2 border-slate-200 peer-checked:border-accent peer-checked:bg-accent transition-all mt-0.5">
    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="4" stroke-linecap="round" stroke-linejoin="round" class="peer-checked:opacity-100 opacity-0"><polyline points="20 6 9 17 4 12"></polyline></svg>
  </div>
  <span class="text-[11px] text-slate-500 font-bold leading-relaxed">
    {lang === 'en'
      ? 'I consent to being contacted about this clinical trial in NYC. I understand no clinical data is being collected in this form.'
      : 'Doy mi consentimiento para ser contactado sobre este ensayo clínico en NYC. Entiendo que no se recogen datos clínicos en este formulario.'}
  </span>
</label>
        </div>
      </div>

      <button type="submit" id="submit-btn"
        class="w-full py-6 rounded-[2rem] bg-primary text-white font-black uppercase tracking-[0.2em] shadow-xl shadow-primary/20 hover:bg-accent hover:scale-[1.02] active:scale-[0.98] transition-all flex items-center justify-center gap-3 group/btn">
        <span>{lang === 'en' ? 'Send Application' : 'Enviar Solicitud'}</span>
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="group-hover/btn:translate-x-1 transition-transform"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
      </button>
    </form>

    <!-- Success Message -->
    <div id="results-section" class="hidden py-10 text-center animate-fade-in">
      <div class="w-24 h-24 rounded-full bg-accent/10 flex items-center justify-center mx-auto mb-8 border border-accent/20">
        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="text-accent animate-bounce">
          <polyline points="20 6 9 17 4 12"></polyline>
        </svg>
      </div>
      <h3 class="text-3xl font-black text-primary mb-4 tracking-tighter">
        {lang === 'en' ? 'Application Sent!' : '¡Solicitud Enviada!'}
      </h3>
      <p class="text-slate-600 font-medium mb-8 max-w-sm mx-auto">
        {lang === 'en'
          ? 'Thank you for your interest. A medical coordinator from the NYC clinical site will reach out to you within 24 hours.'
          : 'Gracias por tu interés. Un coordinador médico del centro clínico de NYC se pondrá en contacto contigo en 24 horas.'}
      </p>
      <button id="close-modal-success" class="px-8 py-3 rounded-xl bg-slate-100 text-primary font-black text-xs uppercase tracking-widest hover:bg-slate-200 transition-all">
        {lang === 'en' ? 'Close' : 'Cerrar'}
      </button>
    </div>
  </div>
  <HIPAAAuthorization lang={lang} />
</div>

<script define:vars={{ lang, trialNctId: trial?.nct_id, trialTitle: trial?.title }}>
  const form = document.getElementById('prescreen-form');
  const resultsSection = document.getElementById('results-section');
  const submitBtn = document.getElementById('submit-btn');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    if (typeof window.showHIPAAAuthorization === 'function') {
      window.showHIPAAAuthorization(async () => {
        submitBtn.disabled = true;
        const originalText = submitBtn.innerHTML;
        submitBtn.innerHTML = `<span class="flex items-center gap-2 animate-pulse">${lang === 'en' ? 'Processing...' : 'Procesando...'}</span>`;

        const fd = new FormData(form);
        const payload = {
          firstName: fd.get('firstName'),
          lastName: fd.get('lastName') || '',
          email: fd.get('email'),
          phone: fd.get('phone'),
          trialId: trialNctId || '',
          trialTitle: trialTitle || '',
          hipaaAuthorized: true,
          authorizedAt: new Date().toISOString()
        };

        try {
          const res = await fetch('/api/leads', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload),
          });
          
          if (res.ok) {
            form.classList.add('hidden');
            resultsSection.classList.remove('hidden');
          } else {
            throw new Error('Failed');
          }
        } catch {
          // Fallback success for demo
          form.classList.add('hidden');
          resultsSection.classList.remove('hidden');
        }
      });
    }
  });

  document.getElementById('close-modal-success')?.addEventListener('click', () => {
    window.location.reload();
  });
</script>

