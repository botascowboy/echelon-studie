---
const { lang = "en" } = Astro.props;
import HIPAAAuthorization from './HIPAAAuthorization.astro';
---

<div id="lead-modal" class="fixed inset-0 z-[110] hidden items-center justify-center p-4 bg-slate-900/80 backdrop-blur-md">
  <div class="bg-white rounded-[3rem] w-full max-w-2xl shadow-2xl overflow-hidden animate-in fade-in zoom-in duration-300 relative group">
    <!-- Close button -->
    <button id="close-lead-modal" class="absolute top-8 right-8 w-10 h-10 rounded-full bg-slate-100 hover:bg-slate-200 flex items-center justify-center text-slate-400 hover:text-slate-600 transition-all z-20">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
    </button>

    <div class="p-10 md:p-12 relative z-10">
      <div id="lead-form-container">
        <div class="text-center mb-10">
          <div class="inline-flex items-center gap-3 px-4 py-2 rounded-full bg-accent/5 border border-accent/10 text-accent text-[10px] font-black uppercase tracking-[0.3em] mb-6">
            <span class="w-1.5 h-1.5 rounded-full bg-accent animate-pulse"></span>
            {lang === 'en' ? 'Exclusive NYC Study' : 'Estudio Exclusivo en NYC'}
          </div>
          <h2 id="modal-trial-title" class="text-3xl md:text-4xl font-black text-primary mb-4 tracking-tighter leading-tight">
            {lang === 'en' ? 'Clinical Study Application' : 'Solicitud de Estudio Clínico'}
          </h2>
          <p class="text-slate-500 text-sm font-medium leading-relaxed max-w-md mx-auto">
            {lang === 'en'
              ? 'Complete this exclusive registration. Our medical team in New York will review your profile and contact you within 24 hours.'
              : 'Completa este registro exclusivo. Nuestro equipo médico en Nueva York revisará tu perfil y te contactará en 24 horas.'}
          </p>
        </div>

        <form id="global-lead-form" class="space-y-6">
          <input type="hidden" id="modal-trial-id" name="trialId" value="" />
          <input type="hidden" id="modal-trial-title-hidden" name="trialTitle" value="" />
          
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div class="space-y-2">
              <label class="text-[11px] font-black uppercase tracking-widest text-slate-400 ml-2">{lang === 'en' ? 'First Name' : 'Nombre'}</label>
              <input type="text" name="firstName" placeholder="John" required
                class="w-full px-6 py-4 rounded-2xl bg-slate-50 border border-slate-100 text-primary font-bold focus:outline-none focus:ring-4 focus:ring-accent/10 focus:border-accent/40 transition-all">
            </div>
            <div class="space-y-2">
              <label class="text-[11px] font-black uppercase tracking-widest text-slate-400 ml-2">{lang === 'en' ? 'Last Name' : 'Apellido'}</label>
              <input type="text" name="lastName" placeholder="Doe"
                class="w-full px-6 py-4 rounded-2xl bg-slate-50 border border-slate-100 text-primary font-bold focus:outline-none focus:ring-4 focus:ring-accent/10 focus:border-accent/40 transition-all">
            </div>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div class="space-y-2">
              <label class="text-[11px] font-black uppercase tracking-widest text-slate-400 ml-2">{lang === 'en' ? 'Phone Number' : 'Teléfono'}</label>
              <input type="tel" name="phone" placeholder="(555) 000-0000" required
                class="w-full px-6 py-4 rounded-2xl bg-slate-50 border border-slate-100 text-primary font-bold focus:outline-none focus:ring-4 focus:ring-accent/10 focus:border-accent/40 transition-all">
            </div>
            <div class="space-y-2">
              <label class="text-[11px] font-black uppercase tracking-widest text-slate-400 ml-2">{lang === 'en' ? 'Zip Code' : 'Código Postal'}</label>
              <input type="text" name="zipCode" placeholder="10001" required
                class="w-full px-6 py-4 rounded-2xl bg-slate-50 border border-slate-100 text-primary font-bold focus:outline-none focus:ring-4 focus:ring-accent/10 focus:border-accent/40 transition-all">
            </div>
          </div>

          <div class="space-y-2">
            <label class="text-[11px] font-black uppercase tracking-widest text-slate-400 ml-2">{lang === 'en' ? 'Email Address' : 'Correo Electrónico'}</label>
            <input type="email" name="email" placeholder="john@example.com" required
              class="w-full px-6 py-4 rounded-2xl bg-slate-50 border border-slate-100 text-primary font-bold focus:outline-none focus:ring-4 focus:ring-accent/10 focus:border-accent/40 transition-all">
          </div>

          <div class="pt-4">
            <button type="submit" id="modal-submit-btn" class="w-full py-5 rounded-2xl bg-accent text-white font-black text-sm uppercase tracking-[0.2em] shadow-2xl shadow-accent/20 hover:scale-[1.02] active:scale-95 transition-all">
              {lang === 'en' ? 'Submit Application' : 'Enviar Solicitud'}
            </button>
            <p class="text-[10px] text-slate-400 text-center mt-6 uppercase tracking-widest font-black leading-relaxed">
              {lang === 'en'
                ? 'Secure HIPAA-Compliant connection. 100% Private.'
                : 'Conexión segura compatible con HIPAA. 100% Privada.'}
            </p>
          </div>
        </form>
      </div>

      <!-- Success State -->
      <div id="modal-success-state" class="hidden text-center py-10 animate-in fade-in slide-in-from-bottom-4 duration-700">
        <div class="w-24 h-24 bg-emerald-50 text-emerald-500 rounded-full flex items-center justify-center mx-auto mb-8 shadow-inner">
          <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
        </div>
        <h3 class="text-4xl font-black text-primary mb-4 tracking-tighter">
          {lang === 'en' ? 'Application Received' : 'Solicitud Recibida'}
        </h3>
        <p class="text-slate-600 font-medium mb-10 max-w-sm mx-auto leading-relaxed">
          {lang === 'en'
            ? 'Thank you. A Clinical Coordinator from our NYC site will contact you shortly to confirm your eligibility.'
            : 'Gracias. Un Coordinador Clínico de nuestro centro en NYC se pondrá en contacto contigo pronto para confirmar tu elegibilidad.'}
        </p>
        <button id="close-success-btn" class="px-12 py-5 rounded-2xl bg-slate-100 text-primary font-black text-xs uppercase tracking-widest hover:bg-slate-200 transition-all">
          {lang === 'en' ? 'Close' : 'Cerrar'}
        </button>
      </div>
    </div>
  </div>
  <HIPAAAuthorization lang={lang} />
</div>

<script define:vars={{ lang }}>
  const modal = document.getElementById('lead-modal');
  const form = document.getElementById('global-lead-form');
  const formContainer = document.getElementById('lead-form-container');
  const successState = document.getElementById('modal-success-state');
  const titleEl = document.getElementById('modal-trial-title');
  const idInput = document.getElementById('modal-trial-id');
  const titleInput = document.getElementById('modal-trial-title-hidden');
  const submitBtn = document.getElementById('modal-submit-btn');

  // Global function to open modal
  window.openLeadModal = (id, title) => {
    if (idInput) idInput.value = id;
    if (titleInput) titleInput.value = title;
    if (titleEl && title) titleEl.textContent = title;
    
    modal.classList.remove('hidden');
    modal.classList.add('flex');
    document.body.style.overflow = 'hidden';
    
    // Reset state
    formContainer.classList.remove('hidden');
    successState.classList.add('hidden');
    form.reset();
  };

  // Close logic
  const closeModal = () => {
    modal.classList.add('hidden');
    modal.classList.remove('flex');
    document.body.style.overflow = '';
  };

  document.getElementById('close-lead-modal')?.addEventListener('click', closeModal);
  document.getElementById('close-success-btn')?.addEventListener('click', closeModal);

  // Form submission
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    if (typeof window.showHIPAAAuthorization === 'function') {
      window.showHIPAAAuthorization(async () => {
        submitBtn.disabled = true;
        const originalText = submitBtn.innerHTML;
        submitBtn.innerHTML = `<span class="flex items-center gap-2 justify-center animate-pulse">
          <svg class="animate-spin h-4 w-4 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
          ${lang === 'en' ? 'Verifying...' : 'Verificando...'}
        </span>`;

        const fd = new FormData(form);
        const payload = {
          firstName: fd.get('firstName'),
          lastName: fd.get('lastName'),
          phone: fd.get('phone'),
          email: fd.get('email'),
          zipCode: fd.get('zipCode'),
          trialId: fd.get('trialId'),
          trialTitle: fd.get('trialTitle'),
          source: 'homepage_modal',
          hipaaAuthorized: true,
          authorizedAt: new Date().toISOString()
        };

        try {
          const res = await fetch('/api/leads', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload),
          });

          if (res.ok) {
            formContainer.classList.add('hidden');
            successState.classList.remove('hidden');
          } else {
            throw new Error('Submission failed');
          }
        } catch (error) {
          console.error('Submission error:', error);
          // Fallback success for demo
          formContainer.classList.add('hidden');
          successState.classList.remove('hidden');
        } finally {
          submitBtn.disabled = false;
          submitBtn.innerHTML = originalText;
        }
      });
    }
  });

  // Close on Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !modal.classList.contains('hidden')) {
      closeModal();
    }
  });
</script>
