---
const { lang = "en" } = Astro.props;
---

<div id="geo-banner" class="fixed bottom-6 left-6 z-50 transform translate-y-20 opacity-0 transition-all duration-700 ease-out pointer-events-none sm:pointer-events-auto">
  <div class="glass-premium flex items-center gap-4 px-6 py-4 rounded-2xl border border-white/40 shadow-premium group">
    <div class="relative flex h-10 w-10 items-center justify-center rounded-full bg-accent text-white shadow-lg">
      <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-accent opacity-40"></span>
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
    </div>
    
    <div class="pr-2">
      <p id="geo-text" class="text-sm font-bold text-slate-800 leading-tight">
        {lang === 'en' ? 'Finding trials near you...' : 'Buscando ensayos cerca de ti...'}
      </p>
      <p id="geo-subtext" class="text-[11px] font-semibold text-accent mt-0.5 uppercase tracking-wide">
        {lang === 'en' ? 'Live Location Service' : 'Servicio de Ubicación en Vivo'}
      </p>
    </div>

    <button id="close-geo" class="p-1 hover:bg-slate-100 rounded-lg transition-colors text-slate-400">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
    </button>
  </div>
</div>

<script is:inline define:vars={{ lang }}>
  async function updateGeo() {
    const banner = document.getElementById('geo-banner');
    const geoText = document.getElementById('geo-text');
    const closeBtn = document.getElementById('close-geo');

    if (!banner || !geoText) return;

    try {
      // 1. Get city from IP (reliable for local dev & production)
      const response = await fetch('https://ipapi.co/json/');
      const data = await response.json();
      
      const city = data.city || (lang === 'en' ? 'your area' : 'tu zona');
      const count = Math.floor(Math.random() * 15) + 8; // Simulate count based on city

      if (lang === 'en') {
        geoText.innerHTML = `There are <span class="text-accent font-black">${count}</span> weight-loss studies active in <span class="text-primary font-black">${city}</span>.`;
      } else {
        geoText.innerHTML = `Hay <span class="text-accent font-black">${count}</span> estudios de peso activos en <span class="text-primary font-black">${city}</span>.`;
      }

      // 2. Show banner
      setTimeout(() => {
        banner.classList.remove('translate-y-20', 'opacity-0');
      }, 1500);

    } catch (e) {
      console.error('Geo error:', e);
      // Fallback: don't show or show generic
      if (lang === 'en') {
        geoText.innerHTML = `Multiple weight-loss studies available in <span class="text-primary font-black">Major US Cities</span>.`;
      } else {
        geoText.innerHTML = `Múltiples estudios de peso disponibles en <span class="text-primary font-black">Ciudades Principales</span>.`;
      }
      setTimeout(() => {
        banner.classList.remove('translate-y-20', 'opacity-0');
      }, 1500);
    }

    closeBtn?.addEventListener('click', () => {
      banner.classList.add('translate-y-20', 'opacity-0');
      setTimeout(() => banner.remove(), 700);
    });
  }

  // Initialize
  updateGeo();
</script>

<style>
  .shadow-premium {
    box-shadow: 0 20px 50px -12px rgba(0, 0, 0, 0.15);
  }
</style>
