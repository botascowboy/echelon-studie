---
const { lang = "en" } = Astro.props;
---

<section class="relative min-h-[90vh] flex items-center justify-center overflow-hidden bg-[#001529] pt-20">
    <!-- Luxury Cinematic Background -->
    <div class="absolute inset-0 z-0">
        <div class="absolute inset-0 bg-gradient-to-br from-[#001529] via-[#002147] to-[#001020]"></div>
        <!-- Glowing Orbs -->
        <div class="absolute -top-[20%] -left-[10%] w-[60%] h-[60%] bg-accent/20 rounded-full blur-[120px] animate-pulse"></div>
        <div class="absolute -bottom-[20%] -right-[10%] w-[50%] h-[50%] bg-primary/30 rounded-full blur-[120px] animate-pulse" style="animation-duration: 8s;"></div>
        <!-- Grain Texture -->
        <div class="absolute inset-0 opacity-20 mix-blend-overlay pointer-events-none" style="background-image: url('https://grainy-gradients.vercel.app/noise.svg');"></div>
    </div>

    <div class="container mx-auto px-4 relative z-10">
        <div class="max-w-5xl mx-auto text-center">
            <!-- Luxury Badge -->
            <div class="inline-flex items-center gap-3 px-6 py-3 rounded-full border border-white/10 bg-white/5 backdrop-blur-xl text-white/90 text-[10px] font-black uppercase tracking-[0.5em] mb-12 animate-fade-in shadow-2xl">
                <span class="flex h-2 w-2 rounded-full bg-accent animate-ping"></span>
                {lang === 'en' ? 'Exclusive NYC Clinical Network' : 'Red Clínica Exclusiva de NYC'}
            </div>

            <h1 class="text-5xl md:text-8xl lg:text-[7rem] font-black text-white mb-8 leading-[0.95] tracking-tighter animate-title h-auto py-2">
                {lang === 'en' ? 'The Future of' : 'El Futuro de la'} <br/>
                <span class="text-gradient filter drop-shadow-[0_20px_50px_rgba(0,163,129,0.3)]">
                    {lang === 'en' ? 'Medical Research.' : 'Investigación Médica.'}
                </span>
            </h1>
            
            <p class="text-lg md:text-2xl text-white/60 mb-16 max-w-2xl mx-auto leading-relaxed font-medium animate-fade-in-up" style="animation-delay: 0.2s;">
                {lang === 'en' 
                    ? 'Direct access to breakthrough clinical trials in the five boroughs. Join New York\'s elite medical registry today.' 
                    : 'Acceso directo a ensayos clínicos innovadores en los cinco condados. Únete hoy al registro médico de élite de Nueva York.'}
            </p>

            <div class="flex flex-col sm:flex-row items-center justify-center gap-6 animate-fade-in-up" style="animation-delay: 0.4s;">
                <a href="#trials" class="group relative px-12 py-6 bg-white rounded-2xl font-black text-primary text-sm uppercase tracking-[0.2em] transition-all hover:scale-105 active:scale-95 shadow-[0_20px_50px_-10px_rgba(255,255,255,0.3)] overflow-hidden">
                    <span class="relative z-10">{lang === 'en' ? 'View NYC Trials' : 'Ver Ensayos en NYC'}</span>
                    <div class="absolute inset-0 bg-gradient-to-r from-accent/20 to-transparent translate-x-[-100%] group-hover:translate-x-0 transition-transform duration-500"></div>
                </a>
                <a href="#contact" class="px-12 py-6 rounded-2xl font-black text-white text-sm uppercase tracking-[0.2em] border-2 border-white/10 hover:bg-white/5 transition-all backdrop-blur-sm">
                    {lang === 'en' ? 'Join Registry' : 'Unirse al Registro'}
                </a>
            </div>

            <!-- Precision Stats Row -->
            <div class="grid grid-cols-2 lg:grid-cols-4 gap-8 mt-32 pt-16 border-t border-white/5 animate-fade-in" style="animation-delay: 0.6s;">
                {[
                    { label: lang === 'en' ? 'Active NYC Trials' : 'Ensayos en NYC', value: '450+' },
                    { label: lang === 'en' ? 'Research Centers' : 'Centros de Inv.', value: '12' },
                    { label: lang === 'en' ? 'Total Stipends' : 'Compensación Total', value: '$25M+' },
                    { label: lang === 'en' ? 'Medical Board' : 'Junta Médica', value: 'Elite' }
                ].map(stat => (
                    <div class="text-center group cursor-default">
                        <div class="text-3xl md:text-4xl font-black text-white mb-2 group-hover:text-accent transition-colors tracking-tighter">{stat.value}</div>
                        <div class="text-[10px] font-black text-white/30 uppercase tracking-[0.2em] group-hover:text-white/50 transition-colors">{stat.label}</div>
                    </div>
                ))}
            </div>
        </div>
    </div>
</section>

<style>
    @keyframes title {
        from { opacity: 0; transform: translateY(30px) scale(0.98); }
        to { opacity: 1; transform: translateY(0) scale(1); }
    }
    .animate-title {
        animation: title 1.2s cubic-bezier(0.23, 1, 0.32, 1) forwards;
    }
    @keyframes fade-in-up {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }
    .animate-fade-in-up {
        opacity: 0;
        animation: fade-in-up 1s cubic-bezier(0.23, 1, 0.32, 1) forwards;
    }
</style>
