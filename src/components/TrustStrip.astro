---
const { lang = "en" } = Astro.props;
---

<!-- Trust / Social Proof strip -->
<section class="bg-slate-50 border-y border-slate-100 py-12">
  <div class="mx-auto w-full max-w-screen-xl px-4 md:px-8">

    <!-- Stats row -->
    <div class="flex flex-wrap items-center justify-center gap-x-12 gap-y-6 mb-10">
      {[
        { icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 3H5a2 2 0 0 0-2 2v4m6-6h10a2 2 0 0 1 2 2v4M9 3v18m0 0h10a2 2 0 0 0 2-2V9M9 21H5a2 2 0 0 1-2-2V9m0 0h18"/></svg>`, stat: '200+', label: lang === 'en' ? 'Active Trials' : 'Ensayos Activos' },
        { icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`, stat: '5,000+', label: lang === 'en' ? 'Patients Enrolled' : 'Pacientes Enrolados' },
        { icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>`, stat: '$1,500', label: lang === 'en' ? 'Max Compensation' : 'Compensación Máx.' },
        { icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>`, stat: '5', label: lang === 'en' ? 'Major US Cities' : 'Ciudades Principales' },
      ].map(({ icon, stat, label }) => (
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 rounded-full bg-white border border-slate-200 flex items-center justify-center text-slate-400 flex-shrink-0" set:html={icon}></div>
          <div>
            <div class="text-lg font-extrabold text-slate-900 leading-none">{stat}</div>
            <div class="text-xs font-semibold text-slate-400 mt-0.5">{label}</div>
          </div>
        </div>
      ))}
    </div>

    <!-- Trust badges row -->
    <div class="flex flex-wrap items-center justify-center gap-4">
      <p class="text-xs font-bold text-slate-400 uppercase tracking-widest mr-2">
        {lang === 'en' ? 'Verified & Compliant' : 'Verificado y Conforme'}
      </p>
      {[
        { label: 'FDA Regulated', color: 'bg-blue-50 border-blue-100 text-blue-700' },
        { label: 'IRB Approved', color: 'bg-purple-50 border-purple-100 text-purple-700' },
        { label: 'HIPAA Compliant', color: 'bg-green-50 border-green-100 text-green-700' },
        { label: 'ClinicalTrials.gov', color: 'bg-slate-50 border-slate-200 text-slate-600' },
      ].map(({ label, color }) => (
        <span class={`inline-flex items-center gap-1.5 px-3.5 py-1.5 rounded-full border text-[11px] font-bold ${color}`}>
          <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          {label}
        </span>
      ))}
    </div>

  </div>
</section>
