---
const { lang = "en" } = Astro.props;

const cities = [
  { id: 'nyc', name: 'New York', short: 'NYC', state: 'NY', lat: 40.7128, lon: -74.006, trials: 42, icon: '🗽' },
  { id: 'miami', name: 'Miami', short: 'Miami', state: 'FL', lat: 25.7617, lon: -80.1918, trials: 28, icon: '🌴' },
  { id: 'houston', name: 'Houston', short: 'Houston', state: 'TX', lat: 29.7604, lon: -95.3698, trials: 35, icon: '🚀' },
  { id: 'losangeles', name: 'Los Angeles', short: 'LA', state: 'CA', lat: 34.0522, lon: -118.2437, trials: 31, icon: '🌆' },
  { id: 'sanfrancisco', name: 'San Francisco', short: 'SF', state: 'CA', lat: 37.7749, lon: -122.4194, trials: 24, icon: '🌉' },
];
---

<section id="map-section" class="py-16 md:py-24 bg-slate-50 overflow-hidden">
  <div class="mx-auto max-w-screen-xl px-4 md:px-8">

    <!-- Section heading -->
    <div class="text-center mb-12 max-w-2xl mx-auto">
      <div class="mb-4 inline-flex items-center gap-2 rounded-full border border-accent/20 bg-accent/5 px-4 py-1.5">
        <span class="text-[11px] font-black uppercase tracking-[0.2em] text-accent">
          {lang === 'en' ? '5 Major Cities' : '5 Ciudades Principales'}
        </span>
      </div>
      <h2 class="text-3xl md:text-5xl font-extrabold mb-5 tracking-tight text-slate-900">
        {lang === 'en' ? 'Nationwide' : 'Cobertura'} <span style="color:#00a381">{lang === 'en' ? 'Coverage' : 'Nacional'}</span>
      </h2>
      <p class="text-slate-500 text-lg font-medium leading-relaxed">
        {lang === 'en'
          ? 'We connect patients with weight-loss clinical trials across the United States. Click a city to explore available studies.'
          : 'Conectamos pacientes con ensayos clínicos de pérdida de peso en todo Estados Unidos. Haz clic en una ciudad para explorar los estudios disponibles.'}
      </p>
    </div>

    <!-- Map card -->
    <div class="relative w-full max-w-5xl mx-auto bg-white rounded-3xl border border-slate-200 shadow-xl overflow-hidden">
      
      <!-- Map container with fixed aspect ratio -->
      <div id="map-container" class="relative w-full" style="height: 560px;">
        <svg id="us-map" class="w-full h-full"></svg>

        <!-- Tooltip -->
        <div id="map-tooltip" class="absolute pointer-events-none opacity-0 transition-all duration-200 z-30 px-5 py-3 rounded-2xl shadow-2xl border border-slate-200 bg-white/95 backdrop-blur-md" style="transform: translate(-50%, -120%);">
          <div class="flex items-center gap-3">
            <span id="tooltip-icon" class="text-2xl">🗽</span>
            <div>
              <h4 class="font-extrabold text-sm text-slate-900" id="tooltip-city">New York</h4>
              <p class="text-xs text-slate-500 font-semibold" id="tooltip-trials">42 Active Trials</p>
            </div>
          </div>
        </div>
      </div>

      <!-- City legend cards (bottom) -->
      <div class="grid grid-cols-2 sm:grid-cols-5 border-t border-slate-100">
        {cities.map((city) => (
          <a
            href="#trials"
            data-city-id={city.id}
            data-city-val={`${city.name}, ${city.state}`}
            class="city-legend-card group flex items-center gap-3 px-4 py-4 hover:bg-accent/5 transition-all cursor-pointer border-r border-slate-100 last:border-r-0"
          >
            <span class="text-xl">{city.icon}</span>
            <div>
              <div class="font-bold text-sm text-slate-800 group-hover:text-accent transition-colors">{city.short}</div>
              <div class="text-[11px] text-slate-400 font-semibold">{city.trials} {lang === 'en' ? 'trials' : 'ensayos'}</div>
            </div>
          </a>
        ))}
      </div>
    </div>

  </div>
</section>

<script>
  import * as d3 from 'd3';
  import * as topojson from 'topojson-client';

  const CITIES = [
    { id: 'nyc', name: 'New York', short: 'NYC', state: 'NY', lat: 40.7128, lon: -74.006, trials: 42, icon: '🗽' },
    { id: 'miami', name: 'Miami', short: 'Miami', state: 'FL', lat: 25.7617, lon: -80.1918, trials: 28, icon: '🌴' },
    { id: 'houston', name: 'Houston', short: 'Houston', state: 'TX', lat: 29.7604, lon: -95.3698, trials: 35, icon: '🚀' },
    { id: 'losangeles', name: 'Los Angeles', short: 'LA', state: 'CA', lat: 34.0522, lon: -118.2437, trials: 31, icon: '🌆' },
    { id: 'sanfrancisco', name: 'San Francisco', short: 'SF', state: 'CA', lat: 37.7749, lon: -122.4194, trials: 24, icon: '🌉' },
  ];

  async function initMap() {
    const container = document.getElementById('map-container');
    if (!container) return;

    const svgEl = document.getElementById('us-map') as unknown as SVGSVGElement;
    if (!svgEl) return;

    // Clear any previous render
    while (svgEl.firstChild) svgEl.removeChild(svgEl.firstChild);

    const width = container.clientWidth;
    const height = container.clientHeight;

    const svg = d3.select(svgEl)
      .attr('viewBox', `0 0 ${width} ${height}`)
      .attr('preserveAspectRatio', 'xMidYMid meet');

    // Defs for gradients & filters
    const defs = svg.append('defs');

    // State fill gradient
    const grad = defs.append('linearGradient')
      .attr('id', 'state-fill')
      .attr('x1', '0%').attr('y1', '0%')
      .attr('x2', '100%').attr('y2', '100%');
    grad.append('stop').attr('offset', '0%').attr('stop-color', '#e0f2fe');
    grad.append('stop').attr('offset', '100%').attr('stop-color', '#e0e7ff');

    // State hover gradient
    const gradHover = defs.append('linearGradient')
      .attr('id', 'state-hover')
      .attr('x1', '0%').attr('y1', '0%')
      .attr('x2', '100%').attr('y2', '100%');
    gradHover.append('stop').attr('offset', '0%').attr('stop-color', '#bae6fd');
    gradHover.append('stop').attr('offset', '100%').attr('stop-color', '#c7d2fe');

    // Drop shadow for city markers
    const shadow = defs.append('filter')
      .attr('id', 'marker-shadow')
      .attr('x', '-50%').attr('y', '-50%')
      .attr('width', '200%').attr('height', '200%');
    shadow.append('feDropShadow')
      .attr('dx', '0').attr('dy', '2')
      .attr('stdDeviation', '4')
      .attr('flood-color', '#002147')
      .attr('flood-opacity', '0.18');

    // Pulse animation via CSS
    const style = defs.append('style');
    style.text(`
      @keyframes mapPulse {
        0%   { r: 18; opacity: 0.35; }
        100% { r: 30; opacity: 0; }
      }
      .pulse-ring { animation: mapPulse 2s ease-out infinite; }
    `);

    const g = svg.append('g');

    // Projection
    const projection = d3.geoAlbersUsa()
      .scale(width * 1.15)
      .translate([width / 2, height / 2]);

    const path = d3.geoPath().projection(projection);

    const tooltip = document.getElementById('map-tooltip')!;
    const tooltipIcon = document.getElementById('tooltip-icon')!;
    const tooltipCity = document.getElementById('tooltip-city')!;
    const tooltipTrials = document.getElementById('tooltip-trials')!;

    try {
      // Load US TopoJSON
      const us = await d3.json('https://cdn.jsdelivr.net/npm/us-atlas@3/states-10m.json') as any;
      const states = topojson.feature(us, us.objects.states) as any;

      // Draw states
      g.selectAll('.state')
        .data(states.features)
        .enter()
        .append('path')
        .attr('d', path as any)
        .attr('fill', 'url(#state-fill)')
        .attr('stroke', '#cbd5e1')
        .attr('stroke-width', 0.6)
        .attr('cursor', 'pointer')
        .on('mouseover', function() {
          d3.select(this)
            .transition().duration(180)
            .attr('fill', 'url(#state-hover)')
            .attr('stroke', '#94a3b8')
            .attr('stroke-width', 1);
        })
        .on('mouseout', function() {
          d3.select(this)
            .transition().duration(260)
            .attr('fill', 'url(#state-fill)')
            .attr('stroke', '#cbd5e1')
            .attr('stroke-width', 0.6);
        });

      // Draw state borders overlay
      g.append('path')
        .datum(topojson.mesh(us, us.objects.states, (a: any, b: any) => a !== b))
        .attr('fill', 'none')
        .attr('stroke', '#94a3b8')
        .attr('stroke-width', 0.3)
        .attr('d', path as any);

      // City markers
      CITIES.forEach((city) => {
        const coords = projection([city.lon, city.lat]);
        if (!coords) return;
        const [cx, cy] = coords;

        // Pulse ring
        g.append('circle')
          .attr('cx', cx).attr('cy', cy)
          .attr('r', 18)
          .attr('fill', '#00a381')
          .attr('class', 'pulse-ring');

        // Outer glow
        g.append('circle')
          .attr('cx', cx).attr('cy', cy)
          .attr('r', 14)
          .attr('fill', '#00a381')
          .attr('opacity', 0.15)
          .attr('filter', 'url(#marker-shadow)');

        // Main marker
        g.append('circle')
          .attr('cx', cx).attr('cy', cy)
          .attr('r', 8)
          .attr('fill', '#00a381')
          .attr('stroke', 'white')
          .attr('stroke-width', 3)
          .attr('cursor', 'pointer')
          .attr('filter', 'url(#marker-shadow)')
          .on('mouseover', function(event: MouseEvent) {
            d3.select(this).transition().duration(200)
              .attr('r', 12)
              .attr('fill', '#002147');

            tooltipIcon.textContent = city.icon;
            tooltipCity.textContent = `${city.name}, ${city.state}`;
            tooltipTrials.textContent = `${city.trials} Active Trials`;

            tooltip.style.opacity = '1';
            tooltip.style.left = cx + 'px';
            tooltip.style.top = (cy - 10) + 'px';
          })
          .on('mouseout', function() {
            d3.select(this).transition().duration(200)
              .attr('r', 8)
              .attr('fill', '#00a381');

            tooltip.style.opacity = '0';
          })
          .on('click', function() {
            // Navigate to trials filtered by this city
            const el = document.getElementById('location-filter') as HTMLSelectElement;
            if (el) {
              el.value = `${city.name}, ${city.state}`;
              el.dispatchEvent(new Event('change'));
            }
            document.getElementById('trials')?.scrollIntoView({ behavior: 'smooth' });
          });

        // Label
        g.append('text')
          .attr('x', cx)
          .attr('y', cy + 24)
          .attr('text-anchor', 'middle')
          .attr('font-size', '11px')
          .attr('font-weight', '800')
          .attr('fill', '#002147')
          .attr('paint-order', 'stroke')
          .attr('stroke', 'white')
          .attr('stroke-width', 3)
          .attr('stroke-linejoin', 'round')
          .text(city.short);
      });

    } catch (error) {
      console.error('Error loading map:', error);
      // Fallback: show a simple message
      const container = document.getElementById('map-container');
      if (container) {
        container.innerHTML = `
          <div class="flex items-center justify-center h-full">
            <p class="text-slate-400 font-semibold">Map could not be loaded</p>
          </div>
        `;
      }
    }
  }

  // Legend card clicks
  document.querySelectorAll('.city-legend-card').forEach((card) => {
    card.addEventListener('click', (e) => {
      e.preventDefault();
      const cityVal = (card as HTMLElement).dataset.cityVal;
      if (cityVal) {
        const el = document.getElementById('location-filter') as HTMLSelectElement;
        if (el) {
          el.value = cityVal;
          el.dispatchEvent(new Event('change'));
        }
        document.getElementById('trials')?.scrollIntoView({ behavior: 'smooth' });
      }
    });
  });

  // Init
  initMap();

  // Debounced resize
  let resizeTimer: ReturnType<typeof setTimeout>;
  window.addEventListener('resize', () => {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(() => {
      initMap();
    }, 300);
  });
</script>
