---
const { lang = "en" } = Astro.props;
import HIPAAAuthorization from './HIPAAAuthorization.astro';

const content = lang === "en" ? {
  title: "Join the NYC Patient Registry.",
  subtitle: "Connect with breakthrough clinical research in your community. Direct access to leading physicians.",
  steps: [
    {
      title: "Location",
      fields: [
        { 
          label: "Are you willing to attend visits at research clinics in the NYC area?", 
          name: "willing_to_visit", 
          type: "radio", 
          options: ["Yes, I live in or near NYC", "No, I am not in the area"], 
          required: true 
        },
        { label: "Zip Code", name: "zipcode", type: "text", placeholder: "10001", required: true }
      ]
    },
    {
      title: "Contact Info",
      fields: [
        { label: "First Name", name: "first_name", type: "text", required: true },
        { label: "Last Name", name: "last_name", type: "text", required: true },
        { label: "Phone", name: "phone", type: "tel", required: true },
        { label: "Email", name: "email", type: "email", required: true }
      ]
    }
  ],
  legal: "By clicking \"Submit,\" I authorize Echelon Clinical Research to contact me regarding research opportunities. I agree to the [Privacy Policy]. No clinical data is collected here.",
  buttons: {
    next: "Continue",
    prev: "Back",
    submit: "Apply to Registry"
  },
  success: {
    title: "Registration Success!",
    message: "Welcome to the Echelon registry. Our team will contact you shortly.",
    dismiss: "Done"
  }
} : {
  title: "Únete al Registro en NYC.",
  subtitle: "Conéctate con investigación clínica innovadora en tu comunidad.",
  steps: [
    {
      title: "Ubicación",
      fields: [
        { 
          label: "¿Está dispuesto a asistir a visitas en el área de NYC?", 
          name: "willing_to_visit", 
          type: "radio", 
          options: ["Sí, vivo en o cerca de NYC", "No, no estoy en el área"], 
          required: true 
        },
        { label: "Código Postal", name: "zipcode", type: "text", placeholder: "10001", required: true }
      ]
    },
    {
      title: "Información de Contacto",
      fields: [
        { label: "Nombre", name: "first_name", type: "text", required: true },
        { label: "Apellido", name: "last_name", type: "text", required: true },
        { label: "Teléfono", name: "phone", type: "tel", required: true },
        { label: "Correo Electrónico", name: "email", type: "email", required: true }
      ]
    }
  ],
  legal: "Al hacer clic en \"Enviar\", autorizo a Echelon Clinical Research a contactarme. No se recogen datos clínicos aquí.",
  buttons: {
    next: "Continuar",
    prev: "Atrás",
    submit: "Unirse al Registro"
  },
  success: {
    title: "¡Registro Exitoso!",
    message: "Bienvenido al registro de Echelon. Nuestro equipo se pondrá en contacto pronto.",
    dismiss: "Finalizar"
  }
};

---

<section id="contact" class="section-padding relative overflow-hidden bg-slate-50/20">
  <!-- Luxury Ambient Orbs -->
  <div class="absolute -top-20 -right-20 w-[600px] h-[600px] bg-accent/[0.08] rounded-full blur-[120px] -z-10 animate-float"></div>
  <div class="absolute -bottom-20 -left-20 w-[600px] h-[600px] bg-accent/[0.04] rounded-full blur-[120px] -z-10 animate-float" style="animation-delay: 2s;"></div>

  <div class="container mx-auto px-4">
    <div class="max-w-4xl mx-auto bg-white rounded-[4rem] p-10 md:p-20 border border-slate-100 shadow-[0_80px_160px_-40px_rgba(0,163,129,0.12)] relative group">
      <!-- Luxury Internal Glow -->
      <div class="absolute inset-0 bg-gradient-to-br from-accent/[0.02] to-transparent pointer-events-none rounded-[4rem]"></div>
      
      <!-- Form Header -->
      <div class="text-center mb-20 relative z-10">
        <div class="inline-flex items-center gap-3 px-4 py-2 rounded-full border border-accent/20 bg-accent/5 text-accent text-[10px] font-black uppercase tracking-[0.4em] mb-8">
          Secure Registration
        </div>
        <h2 class="text-4xl md:text-7xl font-black mb-6 tracking-tighter text-primary">
          {lang === 'en' ? 'Join the' : 'Únete al'} <span class="text-gradient">{lang === 'en' ? 'Registry.' : 'Registro.'}</span>
        </h2>
        <p class="text-slate-500 text-lg md:text-xl max-w-xl mx-auto font-medium opacity-80">{content.subtitle}</p>
      </div>

      <form 
        id="multi-step-form"
        name="registry" 
        method="POST" 
        class="space-y-12 md:space-y-16 relative z-10"
      >
        <input type="hidden" name="form-name" value="registry" />
        
        <!-- Precision Progress Indicator -->
        <div class="relative flex justify-between items-center mb-20 px-4">
          <!-- Main Progress Track -->
          <div class="absolute top-6 left-12 right-12 h-[2px] bg-slate-100 -z-10 overflow-hidden">
            <div id="progress-line" class="h-full bg-accent transition-all duration-1000 ease-out" style="width: 0%"></div>
          </div>

          {content.steps.map((step, i) => (
            <div class="flex flex-col items-center gap-4 group relative z-10" data-step-nav={i}>
              <div 
                class={`step-indicator w-12 h-12 rounded-2xl flex items-center justify-center font-black text-sm transition-all duration-700 border-2 
                  ${i === 0 ? 'bg-accent border-accent text-white shadow-2xl shadow-accent/30 scale-110' : 'bg-white border-slate-100 text-slate-300'}`}
                data-index={i}
              >
                {i + 1}
              </div>
              <span class={`hidden xs:block text-[9px] font-black uppercase tracking-[0.3em] transition-all duration-700 ${i === 0 ? 'text-accent' : 'text-slate-300'}`}>
                {step.title.split(' ')[0]}
              </span>
            </div>
          ))}
        </div>

        <!-- Dynamic Form Stages -->
        <div class="form-steps-container">
          {content.steps.map((step, i) => (
            <div 
              class={`form-step space-y-10 md:space-y-12 transition-all duration-700 ${i === 0 ? 'block opacity-100' : 'hidden opacity-0 h-0 overflow-hidden'}`}
              data-step={i}
            >
              <div class="flex items-center gap-6 mb-4">
                <span class="w-12 h-1 bg-accent/20 rounded-full"></span>
                <h3 class="text-xl md:text-2xl font-black text-primary tracking-tighter uppercase tracking-[0.1em]">{step.title}</h3>
              </div>
              
              <div class="grid grid-cols-1 gap-8 md:gap-12">
                {step.fields.map(field => (
                  <div class="space-y-5 group">
                    <label class="block text-base font-black text-primary/70 ml-1 group-has-[:focus]:text-accent transition-colors tracking-tighter">
                      {field.label} {field.required && <span class="text-accent">*</span>}
                    </label>

                    {field.type === 'select' ? (
                      <div class="relative">
                        <select 
                          name={field.name} 
                          required={field.required}
                          class="w-full bg-slate-50/50 border border-slate-100 rounded-[2rem] px-8 py-6 focus:outline-none focus:ring-[6px] focus:ring-accent/5 focus:border-accent/40 transition-all text-primary appearance-none text-lg font-bold shadow-sm hover:bg-white"
                        >
                          <option value="" disabled selected>{lang === 'en' ? 'Select Option' : 'Seleccione'}</option>
                          {field.options?.map(opt => <option value={opt}>{opt}</option>)}
                        </select>
                        <div class="absolute right-8 top-1/2 -translate-y-1/2 pointer-events-none text-slate-300">
                          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
                        </div>
                      </div>
                    ) : field.type === 'radio' ? (
                      <div class="grid grid-cols-1 gap-4" data-radio-group={field.name}>
                        {field.options?.map((opt, optIndex) => (
                          <label class="radio-label flex items-center gap-6 p-6 rounded-[2rem] bg-white border border-slate-100 hover:border-accent/30 shadow-sm hover:shadow-xl transition-all duration-500 cursor-pointer active:scale-[0.98]">
                            <div class="radio-indicator relative flex items-center justify-center w-7 h-7 rounded-full border-[3px] border-slate-100 transition-all duration-500">
                              <input 
                                type="radio" 
                                name={field.name} 
                                value={opt} 
                                required={field.required}
                                class="sr-only radio-input" 
                                data-radio-option={optIndex}
                              />
                              <div class="radio-dot w-2.5 h-2.5 rounded-full bg-white opacity-0 transition-all duration-500"></div>
                            </div>
                            <span class="radio-text text-lg font-black text-slate-400 transition-colors duration-500 tracking-tighter">{opt}</span>
                          </label>
                        ))}
                      </div>
                    ) : field.type === 'checkbox' ? (
                      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                        {field.options?.map(opt => (
                          <label class="flex items-center gap-5 p-6 rounded-[2rem] bg-white border border-slate-100 hover:border-accent/30 shadow-sm hover:shadow-xl transition-all duration-500 cursor-pointer group/check active:scale-[0.98]">
                            <div class="relative flex items-center justify-center w-7 h-7 rounded-xl border-[3px] border-slate-100 group-has-[:checked]:border-accent group-has-[:checked]:bg-accent transition-all duration-500">
                              <input 
                                type="checkbox" 
                                name={field.name} 
                                value={opt} 
                                class="sr-only" 
                              />
                              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="4" stroke-linecap="round" stroke-linejoin="round" class="opacity-0 group-has-[:checked]:opacity-100 transition-opacity"><polyline points="20 6 9 17 4 12"></polyline></svg>
                            </div>
                            <span class="text-xs font-black text-slate-400 group-has-[:checked]:text-primary leading-tight transition-colors tracking-[0.05em]">{opt}</span>
                          </label>
                        ))}
                      </div>
                    ) : (
                      <input 
                        type={field.type} 
                        name={field.name} 
                        required={field.required}
                        placeholder={field.placeholder || ''}
                        class="w-full bg-slate-50/50 border border-slate-100 rounded-[2rem] px-8 py-6 focus:outline-none focus:ring-[6px] focus:ring-accent/5 focus:border-accent/40 transition-all text-primary placeholder:text-slate-200 text-lg font-bold shadow-sm hover:bg-white"
                      />
                    )}
                  </div>
                ))}
              </div>

              {i === content.steps.length - 1 && (
                <div class="pt-8 space-y-8">
                  <div class="p-10 rounded-[3rem] bg-slate-50 border border-slate-100 text-sm leading-relaxed text-slate-400 font-bold opacity-80">
                    <p>{content.legal}</p>
                  </div>
                </div>
              )}
            </div>
          ))}
        </div>

        <!-- Global Navigation -->
        <div class="flex flex-col sm:flex-row gap-6 pt-10">
          <button 
            type="button" 
            id="prev-btn" 
            class="hidden flex-1 py-7 rounded-2xl bg-slate-50 border border-slate-100 text-slate-400 font-black text-xs uppercase tracking-[0.3em] hover:bg-slate-100 transition-all active:scale-95 shadow-sm"
          >
            {content.buttons.prev}
          </button>
          <button 
            type="button" 
            id="next-btn" 
            class="flex-1 py-7 rounded-2xl bg-primary text-white font-black text-xs uppercase tracking-[0.4em] shadow-[0_20px_40px_-10px_rgba(0,33,71,0.3)] hover:scale-[1.02] active:scale-95 transition-all"
          >
            {content.buttons.next}
          </button>
          <button 
            type="submit" 
            id="submit-btn" 
            class="hidden flex-1 py-7 rounded-2xl bg-gradient-to-r from-primary to-accent text-white font-black text-xs uppercase tracking-[0.4em] shadow-[0_20px_40px_-10px_rgba(0,163,129,0.3)] hover:scale-[1.02] active:scale-95 transition-all"
          >
            {content.buttons.submit}
          </button>
        </div>
      </form>
    </div>
  <HIPAAAuthorization lang={lang} />
</section>

<script>
  let currentStep = 0;
  const form = document.getElementById('multi-step-form') as HTMLFormElement;
  const steps = document.querySelectorAll('.form-step');
  const indicators = document.querySelectorAll('.step-indicator');
  const nextBtn = document.getElementById('next-btn') as HTMLButtonElement;
  const prevBtn = document.getElementById('prev-btn') as HTMLButtonElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const formContainer = form.parentElement;

  function updateStep(shouldScroll = false) {
    const progressLine = document.getElementById('progress-line');
    if (progressLine) {
      const progress = (currentStep / (steps.length - 1)) * 100;
      progressLine.style.width = `${progress}%`;
    }

    steps.forEach((step, i) => {
      if (i === currentStep) {
        step.classList.remove('hidden', 'opacity-0', 'h-0');
        step.classList.add('block', 'opacity-100');
        // Simple animation entry
        (step as HTMLElement).style.transform = 'translateY(10px)';
        (step as HTMLElement).style.opacity = '0';
        requestAnimationFrame(() => {
          (step as HTMLElement).style.transition = 'all 0.6s cubic-bezier(0.23, 1, 0.32, 1)';
          (step as HTMLElement).style.transform = 'translateY(0)';
          (step as HTMLElement).style.opacity = '1';
        });
      } else {
        step.classList.add('hidden', 'opacity-0', 'h-0');
        step.classList.remove('block', 'opacity-100');
      }
    });

    indicators.forEach((ind, i) => {
      const parent = ind.parentElement;
      const label = parent?.querySelector('span');

      if (i === currentStep) {
        ind.classList.add('bg-accent', 'border-accent', 'text-white', 'scale-110', 'shadow-lg', 'shadow-accent/30');
        ind.classList.remove('bg-white', 'border-slate-200', 'text-slate-300');
        label?.classList.add('text-accent');
        label?.classList.remove('text-slate-300');
      } else if (i < currentStep) {
        ind.classList.add('bg-accent', 'border-accent', 'text-white');
        ind.classList.remove('bg-white', 'border-slate-200', 'text-slate-300', 'scale-110', 'shadow-lg', 'shadow-accent/30');
        label?.classList.add('text-accent');
        label?.classList.remove('text-slate-300');
      } else {
        ind.classList.remove('bg-accent', 'text-white', 'border-accent', 'scale-110', 'shadow-lg', 'shadow-accent/30');
        ind.classList.add('bg-white', 'border-slate-200', 'text-slate-300');
        label?.classList.remove('text-accent');
        label?.classList.add('text-slate-300');
      }
    });

    if (currentStep === 0) {
      prevBtn.classList.add('hidden', 'opacity-0');
      prevBtn.classList.remove('opacity-100');
    } else {
      prevBtn.classList.remove('hidden');
      requestAnimationFrame(() => prevBtn.classList.add('opacity-100'));
    }

    if (currentStep === steps.length - 1) {
      nextBtn.classList.add('hidden');
      submitBtn.classList.remove('hidden');
    } else {
      nextBtn.classList.remove('hidden');
      submitBtn.classList.add('hidden');
    }

    // Scroll to top of the form with an offset only if requested
    if (shouldScroll) {
      const contactSection = document.getElementById('contact');
      if (contactSection) {
        const yOffset = -100; 
        const y = contactSection.getBoundingClientRect().top + window.pageYOffset + yOffset;
        window.scrollTo({top: y, behavior: 'smooth'});
      }
    }
  }

  function validateStep() {
    const currentStepEl = steps[currentStep];
    const inputs = currentStepEl.querySelectorAll('input, select, textarea');
    let isValid = true;

    // Reset styles
    inputs.forEach((input: any) => {
      const parent = input.closest('.space-y-4') || input.parentElement;
      if (parent) parent.classList.remove('ring-4', 'ring-red-500/10');
    });

    inputs.forEach((input: any) => {
      if (input.hasAttribute('required')) {
        let fieldValid = true;
        
        if (input.type === 'radio') {
          const name = input.getAttribute('name');
          const checked = currentStepEl.querySelector(`input[name="${name}"]:checked`);
          if (!checked) fieldValid = false;
        } else if (input.type === 'checkbox') {
          const name = input.getAttribute('name');
          const checked = currentStepEl.querySelectorAll(`input[name="${name}"]:checked`);
          if (checked.length === 0) fieldValid = false;
        } else if (!input.value.trim()) {
          fieldValid = false;
        }

        if (!fieldValid) {
          isValid = false;
          const parent = input.closest('.space-y-4') || input.parentElement;
          if (parent) {
            parent.classList.add('ring-4', 'ring-red-500/10', 'rounded-[2rem]');
            // Shake animation
            parent.style.animation = 'shake 0.4s ease-in-out';
            setTimeout(() => parent.style.animation = '', 400);
          }
        }
      }
    });

    return isValid;
  }

  nextBtn.addEventListener('click', () => {
    if (validateStep()) {
      currentStep++;
      updateStep(true);
    }
  });

  prevBtn.addEventListener('click', () => {
    currentStep--;
    updateStep(true);
  });

  // Handle 'None of the above' logic for checkboxes
  const interestsCheckboxes = document.querySelectorAll('input[name="interests"]') as NodeListOf<HTMLInputElement>;
  const noneOption = Array.from(interestsCheckboxes).find(cb => cb.value.toLowerCase().includes('none') || cb.value.toLowerCase().includes('ninguno'));

  if (noneOption) {
    noneOption.addEventListener('change', () => {
      if (noneOption.checked) {
        interestsCheckboxes.forEach(cb => {
          if (cb !== noneOption) cb.checked = false;
        });
      }
    });

    interestsCheckboxes.forEach(cb => {
      if (cb !== noneOption) {
        cb.addEventListener('change', () => {
          if (cb.checked) noneOption.checked = false;
        });
      }
    });
  }

  // Handle form submission
  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    if (!validateStep()) return;

    const lang = document.documentElement.lang || 'en';

    // Trigger HIPAA Authorization before proceeding
    if (typeof (window as any).showHIPAAAuthorization === 'function') {
      (window as any).showHIPAAAuthorization(async () => {
        submitBtn.disabled = true;
        submitBtn.innerHTML = `<span class="flex items-center justify-center gap-2"><svg class="animate-spin h-5 w-5" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" fill="none"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg> ${lang === 'en' ? 'Sending...' : 'Enviando...'}</span>`;

        try {
          const formData = new FormData(form);
          
          // Map contact form fields to lead schema
          const payload = {
            firstName: formData.get('first_name'),
            lastName: formData.get('last_name'),
            email: formData.get('email'),
            phone: formData.get('phone'),
            city: formData.get('zipcode'), // Using zip as city/location for now
            age: formData.get('dob'),
            conditions: formData.getAll('interests'),
            currentMeds: formData.get('medications'),
            hipaaAuthorized: true,
            authorizedAt: new Date().toISOString()
          };

          const res = await fetch("/api/leads", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(payload),
          });

          if (res.ok) {
            if (formContainer) {
              formContainer.innerHTML = `
                <div class="text-center py-20 space-y-8 animate-fade-in">
                  <div class="w-24 h-24 bg-accent/10 rounded-full flex items-center justify-center mx-auto mb-6 border border-accent/20">
                    <svg class="w-12 h-12 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path>
                    </svg>
                  </div>
                  <h3 class="text-4xl font-black text-primary tracking-tighter">Application Received!</h3>
                  <p class="text-slate-500 text-lg max-w-md mx-auto font-medium">
                    Thank you for joining our registry. Our medical team will review your information and contact you shortly.
                  </p>
                  <button onclick="window.location.reload()" class="mt-10 px-10 py-4 rounded-full bg-slate-100 text-primary hover:bg-slate-200 transition-all font-black text-sm uppercase tracking-widest">
                    Done
                  </button>
                </div>
              `;
            }
          } else {
            throw new Error('Form submission failed');
          }
        } catch (err) {
          console.error(err);
          const errorMsg = lang === 'en' ? 'There was an error submitting the form. Please try again.' : 'Hubo un error al enviar el formulario. Por favor, inténtelo de nuevo.';
          alert(errorMsg);
          submitBtn.disabled = false;
          submitBtn.innerHTML = lang === 'en' ? 'Submit' : 'Enviar';
        }
      });
    }
  });

  // Initial update
  updateStep();

  // Radio button visual state handling
  function initRadioButtons() {
    const radioGroups = document.querySelectorAll('[data-radio-group]');
    
    radioGroups.forEach(group => {
      const radios = group.querySelectorAll('.radio-input');
      
      radios.forEach(radio => {
        radio.addEventListener('change', () => {
          // Reset all in group
          const allLabels = group.querySelectorAll('.radio-label');
          allLabels.forEach(label => {
            label.querySelector('.radio-indicator')?.classList.remove('border-accent', 'bg-accent');
            label.querySelector('.radio-indicator')?.classList.add('border-slate-100');
            label.querySelector('.radio-dot')?.classList.remove('opacity-100');
            label.querySelector('.radio-dot')?.classList.add('opacity-0');
            label.querySelector('.radio-text')?.classList.remove('text-primary');
            label.querySelector('.radio-text')?.classList.add('text-slate-400');
            label.classList.remove('border-accent');
            label.classList.add('border-slate-100');
          });
          
          // Set active
          if (radio.checked) {
            const label = radio.closest('.radio-label');
            if (label) {
              label.querySelector('.radio-indicator')?.classList.add('border-accent', 'bg-accent');
              label.querySelector('.radio-indicator')?.classList.remove('border-slate-100');
              label.querySelector('.radio-dot')?.classList.add('opacity-100');
              label.querySelector('.radio-dot')?.classList.remove('opacity-0');
              label.querySelector('.radio-text')?.classList.add('text-primary');
              label.querySelector('.radio-text')?.classList.remove('text-slate-400');
              label.classList.add('border-accent');
              label.classList.remove('border-slate-100');
            }
          }
        });
      });
    });
  }

  initRadioButtons();

</script>
