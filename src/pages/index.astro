---
// src/pages/index.astro - Language redirect with SEO fallback
const preferredLang = Astro.request.headers.get('accept-language')?.split(',')[0]?.split('-')[0] || 'en';
const redirectUrl = preferredLang === 'es' ? '/es' : '/en';

// Server-side redirect for better SEO
return Astro.redirect(redirectUrl, 302);
---
