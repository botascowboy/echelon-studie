---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ChatBot from '../../components/ChatBot.astro';
import PreScreener from '../../components/PreScreener.astro';
import { TrialsInternalService } from '../../lib/services/trials-internal.service';

const { nctId } = Astro.params;
const lang = "en"; // To be improved later with full i18n routing

if (!nctId) {
  return Astro.redirect('/404');
}

// Fetch trial data directly from service (No fetch over HTTP in SSR)
const result = await TrialsInternalService.getTrialDetails(nctId);
const trial = result?.trial;
const error = !trial ? "Trial not found" : null;

// The service already handles validation and JSON/Array transformation
const eligibilityMust    = trial?.eligibility_summary_must || [];
const eligibilityCannot  = trial?.eligibility_summary_cannot || [];
const whatToExpect       = trial?.ai_what_to_expect || [];
const risks              = trial?.ai_potential_risks || [];
const benefits           = trial?.ai_potential_benefits || [];
const questions          = trial?.ai_questions_to_ask || [];
const tags               = trial?.ai_tags || [];
---

<Layout
  title={trial ? `${trial.title} | Weight Loss Trial` : "Trial Not Found"}
  description={trial?.ai_summary || trial?.brief_summary || "Clinical trial details"}
>
  <Header lang={lang} />

  <main class="pt-28 pb-24 bg-slate-50/30">
    {error || !trial ? (
      <div class="container mx-auto px-4 text-center py-24">
        <div class="w-20 h-20 bg-red-50 rounded-full flex items-center justify-center mx-auto mb-6">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/>
          </svg>
        </div>
        <h1 class="text-3xl font-black text-slate-800 mb-3">Trial Not Found</h1>
        <p class="text-slate-500 mb-8">This trial doesn't exist or has ended.</p>
        <a href="/#trials" class="inline-flex items-center gap-2 px-8 py-4 rounded-2xl bg-accent text-white font-black text-sm uppercase tracking-wider hover:bg-primary transition-colors">
          ← Back to All Trials
        </a>
      </div>
    ) : (
      <div class="container mx-auto px-4 max-w-7xl">

        <!-- Breadcrumb -->
        <nav class="flex items-center gap-2 text-sm text-slate-400 mb-8">
          <a href="/" class="hover:text-accent transition-colors">Home</a>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
          <a href="/#trials" class="hover:text-accent transition-colors">Weight Loss Trials</a>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
          <span class="text-slate-700 font-medium truncate max-w-[200px] md:max-w-sm">{trial.title}</span>
        </nav>

        <!-- Hero Card -->
        <div class="relative bg-primary rounded-[3rem] overflow-hidden mb-8 p-10 md:p-14">
          <div class="absolute inset-0 opacity-[0.06]" style="background-image:radial-gradient(circle,#00a381 1px,transparent 1px);background-size:32px 32px;"></div>
          <div class="absolute -top-20 -right-20 w-96 h-96 bg-accent/20 rounded-full blur-[120px] pointer-events-none"></div>
          <div class="relative z-10 max-w-4xl">
            <div class="flex flex-wrap gap-2 mb-5">
              <span class={`text-[10px] font-black uppercase tracking-[0.2em] px-4 py-2 rounded-full ${trial.overall_status === 'RECRUITING' ? 'bg-accent text-white' : 'bg-white/10 text-white/70'}`}>
                {trial.status_label || trial.overall_status}
              </span>
              <span class="text-[10px] font-black uppercase tracking-[0.2em] px-4 py-2 rounded-full bg-white/10 text-white/80">
                {trial.phase_label || trial.phase}
              </span>
              {trial.has_compensation && (
                <span class="text-[10px] font-black uppercase tracking-[0.2em] px-4 py-2 rounded-full bg-emerald-400/20 text-emerald-300 border border-emerald-400/30">
                  💰 Paid Study
                </span>
              )}
            </div>
            <h1 class="text-3xl md:text-5xl font-black text-white leading-[1.1] tracking-tight mb-4">
              {trial.title}
            </h1>
            {tags.length > 0 && (
              <div class="flex flex-wrap gap-2 mt-5">
                {tags.map((tag: string) => (
                  <span class="text-[10px] font-black uppercase tracking-wider px-3 py-1.5 rounded-full bg-white/10 text-white/70 border border-white/10">{tag}</span>
                ))}
              </div>
            )}
          </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
          <!-- LEFT CONTENT -->
          <div class="lg:col-span-2 space-y-6">
            <!-- Summary Section -->
            <div class="bg-gradient-to-br from-accent/5 to-accent/[0.015] rounded-[2.5rem] p-8 md:p-10 border border-accent/10 shadow-sm">
              <div class="flex items-center gap-3 mb-5">
                <div class="w-10 h-10 rounded-xl bg-accent/10 flex items-center justify-center text-accent">
                   ✨
                </div>
                <span class="text-[11px] font-black uppercase tracking-[0.2em] text-accent">Study Overview</span>
              </div>
              <p class="text-slate-700 text-lg leading-relaxed font-medium">
                {trial.ai_summary || trial.brief_summary}
              </p>
              
              <div class="grid grid-cols-2 sm:grid-cols-3 gap-3 mt-7">
                <div class="bg-white rounded-2xl p-4 text-center border border-slate-100 shadow-sm transition-transform hover:scale-[1.02]">
                  <div class="text-xl font-black text-accent leading-tight">{trial.ai_estimated_duration || 'TBD'}</div>
                  <div class="text-[9px] font-black uppercase tracking-widest text-slate-400 mt-1">Duration</div>
                </div>
                <div class="bg-white rounded-2xl p-4 text-center border border-slate-100 shadow-sm transition-transform hover:scale-[1.02]">
                  <div class="text-xl font-black text-primary leading-tight">{trial.ai_visit_frequency || 'Check'}</div>
                  <div class="text-[9px] font-black uppercase tracking-widest text-slate-400 mt-1">Visits</div>
                </div>
                <div class="bg-white rounded-2xl p-4 text-center border border-slate-100 shadow-sm transition-transform hover:scale-[1.02]">
                  <div class="text-xl font-black text-primary leading-tight">{trial.enrollment_count || '...'}</div>
                  <div class="text-[9px] font-black uppercase tracking-widest text-slate-400 mt-1">Goal</div>
                </div>
              </div>
            </div>

            <!-- Eligibility Grid -->
            <div class="bg-white rounded-[2.5rem] p-8 md:p-10 border border-slate-100 shadow-sm">
              <h2 class="text-2xl font-black text-primary mb-7 flex items-center gap-3">
                <div class="w-9 h-9 rounded-xl bg-accent/10 flex items-center justify-center text-accent">📋</div>
                Do I Qualify?
              </h2>

              <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
                <div class="bg-emerald-50 rounded-2xl p-6 border border-emerald-100 h-full">
                  <div class="flex items-center gap-2 mb-4 text-emerald-700">
                    <div class="w-6 h-6 rounded-full bg-emerald-100 flex items-center justify-center">✓</div>
                    <span class="text-xs font-black uppercase tracking-widest">Inclusion</span>
                  </div>
                  <ul class="space-y-3">
                    {eligibilityMust.map((item: string) => (
                      <li class="flex items-start gap-3 text-sm text-emerald-800/90 leading-snug">
                        <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 mt-1.5 flex-shrink-0"></span>
                        {item}
                      </li>
                    ))}
                  </ul>
                </div>

                <div class="bg-red-50 rounded-2xl p-6 border border-red-100 h-full">
                  <div class="flex items-center gap-2 mb-4 text-red-700">
                    <div class="w-6 h-6 rounded-full bg-red-100 flex items-center justify-center">✕</div>
                    <span class="text-xs font-black uppercase tracking-widest">Exclusion</span>
                  </div>
                  <ul class="space-y-3">
                    {eligibilityCannot.map((item: string) => (
                      <li class="flex items-start gap-3 text-sm text-red-800/90 leading-snug">
                        <span class="w-1.5 h-1.5 rounded-full bg-red-400 mt-1.5 flex-shrink-0"></span>
                        {item}
                      </li>
                    ))}
                  </ul>
                </div>
              </div>

              <div class="flex flex-wrap gap-3 pt-6 border-t border-slate-100">
                <div class="flex items-center gap-2 px-4 py-2.5 rounded-xl bg-slate-50 border border-slate-100 text-xs text-slate-600 font-bold">
                  Age: <span class="text-primary">{trial.eligibility_age_range}</span>
                </div>
                <div class="flex items-center gap-2 px-4 py-2.5 rounded-xl bg-slate-50 border border-slate-100 text-xs text-slate-600 font-bold">
                  Sex: <span class="text-primary">{trial.sex}</span>
                </div>
              </div>
            </div>

            <!-- What will I do -->
            {whatToExpect.length > 0 && (
              <div class="bg-white rounded-[2.5rem] p-8 md:p-10 border border-slate-100 shadow-sm">
                <h2 class="text-2xl font-black text-primary mb-7 flex items-center gap-3">
                  <div class="w-9 h-9 rounded-xl bg-accent/10 flex items-center justify-center">⚡</div>
                  Procedures & Steps
                </h2>
                <div class="space-y-4">
                  {whatToExpect.map((item: string, i: number) => (
                    <div class="flex items-start gap-4 p-5 rounded-2xl bg-slate-50 border border-slate-100 hover:border-accent hover:shadow-md transition-all">
                      <div class="w-10 h-10 rounded-full bg-accent text-white flex items-center justify-center flex-shrink-0 font-black text-sm">
                        {i + 1}
                      </div>
                      <span class="text-slate-700 text-sm leading-relaxed">{item}</span>
                    </div>
                  ))}
                </div>
              </div>
            )}
            
            <!-- Questions Section -->
            {questions.length > 0 && (
              <div class="bg-slate-900 rounded-[2.5rem] p-8 md:p-10 text-white overflow-hidden relative border border-white/5">
                <div class="absolute inset-0 bg-gradient-to-br from-accent/20 to-transparent pointer-events-none"></div>
                <div class="relative z-10">
                  <h2 class="text-2xl font-black mb-2 flex items-center gap-3">
                    <div class="w-9 h-9 rounded-xl bg-accent flex items-center justify-center">?</div>
                    Ask the Study Team
                  </h2>
                  <p class="text-white/50 text-xs mb-6 uppercase tracking-widest font-black">Recommended Questions</p>
                  <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                    {questions.map((item: string) => (
                      <div class="p-4 rounded-xl bg-white/5 border border-white/10 text-xs text-white/80 leading-relaxed hover:bg-white/10 transition-colors cursor-default">
                        {item}
                      </div>
                    ))}
                  </div>
                </div>
              </div>
            )}

            <!-- Admin Details -->
            <div class="flex flex-wrap items-center gap-4 px-6 py-4 bg-white rounded-2xl border border-slate-100 text-[10px] font-black uppercase tracking-widest text-slate-400">
              <span>NCT ID: {trial.nct_id}</span>
              <a href={`https://clinicaltrials.gov/study/${trial.nct_id.split('-')[0]}`} target="_blank" class="ml-auto text-accent hover:underline">Verify official source →</a>
            </div>
          </div>

          <!-- RIGHT SIDEBAR -->
          <div class="lg:col-span-1">
            <div class="sticky top-28 space-y-5">
              
              <!-- Premium CTA card -->
              <div class="bg-primary rounded-[2.5rem] p-8 text-white overflow-hidden relative shadow-2xl">
                <div class="absolute -top-12 -right-12 w-48 h-48 bg-accent/30 rounded-full blur-[80px]"></div>
                <div class="relative z-10">
                  <div class="inline-flex items-center gap-2 px-3 py-1 bg-white/10 rounded-full border border-white/10 text-[9px] font-black uppercase tracking-widest mb-4">
                     Available Now
                  </div>
                  <h3 class="text-2xl font-black mb-2 tracking-tight">Check Eligibility</h3>
                  <p class="text-white/60 text-sm mb-8 leading-relaxed">
                    Start your application and see if you qualify for this research study in less than 2 minutes.
                  </p>
                  <a href="#prescreen" class="block w-full py-5 rounded-2xl bg-accent text-white font-black text-center uppercase tracking-widest text-xs hover:bg-white hover:text-primary transition-all shadow-xl shadow-accent/20 active:scale-95">
                    Apply Online
                  </a>
                  <div class="flex items-center justify-center gap-4 mt-6">
                     <div class="flex items-center gap-1.5"><span class="text-accent">✓</span> <span class="text-[9px] uppercase tracking-tighter text-white/40">Free</span></div>
                     <div class="flex items-center gap-1.5"><span class="text-accent">✓</span> <span class="text-[9px] uppercase tracking-tighter text-white/40">Secure</span></div>
                     <div class="flex items-center gap-1.5"><span class="text-accent">✓</span> <span class="text-[9px] uppercase tracking-tighter text-white/40">Private</span></div>
                  </div>
                </div>
              </div>

              <!-- Compensation Box -->
              {trial.has_compensation && (
                <div class="bg-gradient-to-br from-emerald-50 to-white rounded-[2.5rem] p-8 border border-emerald-100 shadow-sm transition-all hover:shadow-md">
                   <div class="flex items-center gap-2 mb-4">
                      <div class="w-8 h-8 rounded-lg bg-emerald-100 flex items-center justify-center text-emerald-600">💰</div>
                      <span class="text-[10px] font-black uppercase tracking-wider text-emerald-600">Compensation</span>
                   </div>
                   <div class="text-4xl font-black text-emerald-700 leading-tight mb-2">
                     {trial.compensation_amount || 'Amount varies'}
                   </div>
                   <p class="text-xs text-emerald-600/70 font-medium">Eligible participants receive payment for clinic visits and travel.</p>
                </div>
              )}

              <!-- Details Sidebar -->
              <div class="bg-white rounded-[2.5rem] p-8 border border-slate-100 shadow-sm space-y-6">
                 <div>
                    <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-3">Facility Location</p>
                    <div class="flex items-start gap-3">
                       <span class="text-accent text-lg">📍</span>
                       <div>
                          <p class="font-black text-slate-800 text-sm leading-tight">{trial.primary_location_city || 'Multiple Cities'}</p>
                          <p class="text-slate-400 text-xs mt-1">{trial.primary_location_state || 'USA'}</p>
                       </div>
                    </div>
                 </div>
                 <div class="pt-6 border-t border-slate-50">
                    <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-3">Lead Sponsor</p>
                    <p class="font-black text-slate-800 text-sm leading-tight underline decoration-accent/30 decoration-2 underline-offset-4">{trial.lead_sponsor || 'Confidential'}</p>
                 </div>
                 <div class="pt-6 border-t border-slate-50">
                    <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-4">Safety Standards</p>
                    <div class="flex items-center gap-3 px-4 py-3 bg-accent/5 rounded-xl border border-accent/10">
                       <span class="text-accent">🛡️</span>
                       <span class="text-[10px] font-black uppercase text-accent">IRB Monitored Study</span>
                    </div>
                 </div>
              </div>

            </div>
          </div>
        </div>

        <section id="prescreen" class="mt-16 scroll-mt-32">
          <PreScreener trial={trial} lang={lang} />
        </section>

      </div>
    )}
  </main>

  <ChatBot lang={lang} />
  <Footer lang={lang} />
</Layout>

<style>
  .scroll-mt-32 { scroll-margin-top: 8rem; }
  .text-gradient { background: linear-gradient(135deg, var(--color-primary), var(--color-accent)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
</style>
