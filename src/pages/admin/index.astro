---
export const prerender = false;

// Simple password gate at the page level
const ADMIN_TOKEN = import.meta.env.ADMIN_TOKEN || 'echelon-admin-2024';
const url = new URL(Astro.request.url);
const token = url.searchParams.get('token') || Astro.cookies.get('admin_token')?.value;

if (token !== ADMIN_TOKEN) {
  // Show login form
}

const authed = token === ADMIN_TOKEN;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Echelon Admin — Lead Pipeline</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Manrope', sans-serif; background: #f8fafc; color: #0f172a; min-height: 100vh; }
    .topbar { background: #002147; color: white; padding: 0 2rem; height: 56px; display: flex; align-items: center; justify-content: space-between; }
    .topbar h1 { font-size: 15px; font-weight: 800; letter-spacing: -0.02em; }
    .topbar .badge { background: #00a381; color: white; font-size: 10px; font-weight: 900; letter-spacing: 0.1em; text-transform: uppercase; padding: 2px 10px; border-radius: 99px; }
    .container { max-width: 1200px; margin: 0 auto; padding: 2rem; }
    /* Login */
    .login-card { max-width: 360px; margin: 8rem auto; background: white; border-radius: 1.5rem; padding: 2.5rem; border: 1px solid #e2e8f0; box-shadow: 0 4px 24px rgba(0,0,0,0.06); }
    .login-card h2 { font-size: 20px; font-weight: 800; margin-bottom: 0.5rem; color: #002147; }
    .login-card p { font-size: 13px; color: #64748b; margin-bottom: 1.5rem; }
    /* Stats */
    .stats-row { display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: 1rem; margin-bottom: 2rem; }
    .stat-card { background: white; border: 1px solid #e2e8f0; border-radius: 1rem; padding: 1.25rem 1.5rem; }
    .stat-card .num { font-size: 28px; font-weight: 900; color: #002147; }
    .stat-card .lbl { font-size: 11px; font-weight: 700; color: #94a3b8; text-transform: uppercase; letter-spacing: 0.08em; margin-top: 2px; }
    /* Table */
    .table-wrap { background: white; border: 1px solid #e2e8f0; border-radius: 1.25rem; overflow: hidden; }
    .table-header { padding: 1rem 1.5rem; border-bottom: 1px solid #f1f5f9; display: flex; align-items: center; justify-content: space-between; }
    .table-header h2 { font-size: 14px; font-weight: 800; color: #002147; }
    table { width: 100%; border-collapse: collapse; font-size: 13px; }
    th { text-align: left; padding: 0.75rem 1rem; font-size: 10px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.08em; color: #94a3b8; background: #f8fafc; border-bottom: 1px solid #f1f5f9; }
    td { padding: 0.875rem 1rem; border-bottom: 1px solid #f8fafc; vertical-align: middle; }
    tr:last-child td { border-bottom: none; }
    tr:hover td { background: #f8fafc; }
    /* Score badge */
    .score { display: inline-flex; align-items: center; justify-content: center; width: 36px; height: 36px; border-radius: 50%; font-size: 11px; font-weight: 900; }
    .score.high { background: #d1fae5; color: #065f46; }
    .score.mid { background: #fef9c3; color: #92400e; }
    .score.low { background: #fee2e2; color: #991b1b; }
    /* Status badges */
    .status-badge { display: inline-block; padding: 3px 10px; border-radius: 99px; font-size: 10px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.06em; cursor: pointer; transition: opacity .15s; }
    .status-badge:hover { opacity: .8; }
    .s-new { background: #dbeafe; color: #1e40af; }
    .s-called { background: #ede9fe; color: #5b21b6; }
    .s-qualified { background: #d1fae5; color: #065f46; }
    .s-sent_to_clinic { background: #00a381; color: white; }
    .s-invoiced { background: #002147; color: white; }
    .s-disqualified { background: #fee2e2; color: #991b1b; }
    /* Inputs */
    input[type=text], input[type=password], select, textarea {
      width: 100%; padding: 0.75rem 1rem; border: 1.5px solid #e2e8f0; border-radius: 0.75rem;
      font-family: inherit; font-size: 14px; outline: none; transition: border-color .15s;
    }
    input:focus, select:focus, textarea:focus { border-color: #00a381; }
    .btn-primary { background: #00a381; color: white; border: none; padding: 0.75rem 1.5rem; border-radius: 0.75rem; font-family: inherit; font-size: 13px; font-weight: 800; cursor: pointer; transition: background .15s; }
    .btn-primary:hover { background: #002147; }
    .empty { text-align: center; padding: 4rem 1rem; color: #94a3b8; font-size: 14px; }
    /* Status selector */
    .status-select { font-size: 11px; padding: 4px 8px; border-radius: 8px; border: 1.5px solid #e2e8f0; font-family: inherit; font-weight: 700; cursor: pointer; }
    .filters { display: flex; gap: 0.75rem; margin-bottom: 1.5rem; flex-wrap: wrap; }
    .filter-btn { padding: 6px 14px; border-radius: 99px; font-size: 11px; font-weight: 800; cursor: pointer; border: 1.5px solid #e2e8f0; background: white; color: #64748b; text-transform: uppercase; letter-spacing: 0.06em; transition: all .15s; }
    .filter-btn.active { background: #002147; color: white; border-color: #002147; }
    .phone-link { color: #00a381; font-weight: 700; text-decoration: none; }
    .phone-link:hover { text-decoration: underline; }
  </style>
</head>
<body>

<div class="topbar">
  <h1>Echelon Clinical Studies — Admin</h1>
  <span class="badge">Lead Pipeline</span>
</div>

{!authed ? (
  <!-- Login gate -->
  <div class="login-card">
    <h2>Admin Access</h2>
    <p>Enter the admin token to access the lead pipeline.</p>
    <form method="GET" style="display:flex; flex-direction:column; gap:0.75rem;">
      <input type="password" name="token" placeholder="Admin token" autofocus>
      <button type="submit" class="btn-primary">Access Dashboard</button>
    </form>
  </div>
) : (
  <div class="container">
    <!-- Stats row -->
    <div class="stats-row" id="stats-row">
      <div class="stat-card"><div class="num" id="stat-total">—</div><div class="lbl">Total Leads</div></div>
      <div class="stat-card"><div class="num" id="stat-new">—</div><div class="lbl">New</div></div>
      <div class="stat-card"><div class="num" id="stat-qualified">—</div><div class="lbl">Qualified</div></div>
      <div class="stat-card"><div class="num" id="stat-sent">—</div><div class="lbl">Sent to Clinic</div></div>
      <div class="stat-card"><div class="num" id="stat-invoiced">—</div><div class="lbl">Invoiced</div></div>
      <div class="stat-card" style="border-color:#00a381;"><div class="num" style="color:#00a381;" id="stat-revenue">$0</div><div class="lbl">Est. Revenue</div></div>
    </div>

    <!-- Filters -->
    <div class="filters" id="filter-bar">
      <button class="filter-btn active" data-filter="all">All</button>
      <button class="filter-btn" data-filter="new">New</button>
      <button class="filter-btn" data-filter="called">Called</button>
      <button class="filter-btn" data-filter="qualified">Qualified</button>
      <button class="filter-btn" data-filter="sent_to_clinic">Sent to Clinic</button>
      <button class="filter-btn" data-filter="invoiced">Invoiced</button>
      <button class="filter-btn" data-filter="disqualified">Disqualified</button>
    </div>

    <!-- Table -->
    <div class="table-wrap">
      <div class="table-header">
        <h2>Leads</h2>
        <button class="btn-primary" style="font-size:11px; padding:6px 14px;" onclick="loadLeads()">↻ Refresh</button>
      </div>
      <div id="table-container">
        <div class="empty">Loading leads…</div>
      </div>
    </div>
  </div>
)}

<script define:vars={{ authed, ADMIN_TOKEN }}>
  if (!authed) { /* login form — no JS needed */ }
  else {
    let allLeads = [];
    let currentFilter = 'all';

    const STATUS_LABELS = {
      new: 'New',
      called: 'Called',
      qualified: 'Qualified',
      sent_to_clinic: 'Sent to Clinic',
      invoiced: 'Invoiced',
      disqualified: 'Disqualified',
    };

    async function loadLeads() {
      try {
        const res = await fetch(`/api/leads?token=${ADMIN_TOKEN}`);
        const data = await res.json();
        allLeads = data.leads || [];
        updateStats();
        renderTable();
      } catch (e) {
        document.getElementById('table-container').innerHTML = '<div class="empty">Error loading leads.</div>';
      }
    }

    function updateStats() {
      const byStatus = (s) => allLeads.filter(l => l.status === s).length;
      document.getElementById('stat-total').textContent = allLeads.length;
      document.getElementById('stat-new').textContent = byStatus('new');
      document.getElementById('stat-qualified').textContent = byStatus('qualified');
      document.getElementById('stat-sent').textContent = byStatus('sent_to_clinic');
      document.getElementById('stat-invoiced').textContent = byStatus('invoiced');
      // Est. revenue: $400 per sent/invoiced lead
      const revenue = (byStatus('sent_to_clinic') + byStatus('invoiced')) * 400;
      document.getElementById('stat-revenue').textContent = '$' + revenue.toLocaleString();
    }

    function renderTable() {
      const filtered = currentFilter === 'all' ? allLeads : allLeads.filter(l => l.status === currentFilter);

      if (!filtered.length) {
        document.getElementById('table-container').innerHTML = '<div class="empty">No leads found.</div>';
        return;
      }

      const rows = filtered.map(lead => {
        const score = lead.qualityScore || 0;
        const scoreClass = score >= 60 ? 'high' : score >= 40 ? 'mid' : 'low';
        const date = new Date(lead.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' });
        const conditions = (lead.conditions || []).join(', ') || '—';
        const statusOpts = Object.entries(STATUS_LABELS).map(([v, l]) =>
          `<option value="${v}" ${lead.status === v ? 'selected' : ''}>${l}</option>`
        ).join('');

        return `
          <tr>
            <td>
              <div style="font-weight:800; font-size:13px; color:#002147;">${lead.firstName} ${lead.lastName}</div>
              <div style="font-size:11px; color:#64748b; margin-top:2px;">${date}</div>
            </td>
            <td>
              <a href="tel:${lead.phone}" class="phone-link">${lead.phone}</a>
              <div style="font-size:11px; color:#64748b;">${lead.email}</div>
            </td>
            <td style="color:#475569; font-size:12px;">${lead.city || '—'}</td>
            <td>
              <div style="font-size:11px; font-weight:700; color:#475569;">${lead.bmi || '—'} BMI</div>
              <div style="font-size:10px; color:#94a3b8;">${lead.currentMeds || '—'}</div>
            </td>
            <td style="font-size:11px; color:#64748b; max-width:140px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;" title="${conditions}">${conditions}</td>
            <td style="font-size:10px; color:#64748b; max-width:120px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;" title="${lead.trialTitle || '—'}">${lead.trialId ? `<span style="font-weight:700;">${lead.trialId}</span><br>${lead.trialTitle || ''}` : '—'}</td>
            <td><span class="score ${scoreClass}">${score}</span></td>
            <td>
              <select class="status-select" onchange="updateStatus('${lead.id}', this.value)">
                ${statusOpts}
              </select>
            </td>
          </tr>
        `;
      }).join('');

      document.getElementById('table-container').innerHTML = `
        <table>
          <thead>
            <tr>
              <th>Name</th>
              <th>Contact</th>
              <th>City</th>
              <th>Profile</th>
              <th>Conditions</th>
              <th>Trial</th>
              <th>Score</th>
              <th>Status</th>
            </tr>
          </thead>
          <tbody>${rows}</tbody>
        </table>
      `;
    }

    async function updateStatus(id, status) {
      try {
        await fetch(`/api/leads?token=${ADMIN_TOKEN}`, {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id, status }),
        });
        const lead = allLeads.find(l => l.id === id);
        if (lead) lead.status = status;
        updateStats();
      } catch (e) { console.error(e); }
    }

    // Filter buttons
    document.getElementById('filter-bar')?.addEventListener('click', (e) => {
      const btn = e.target.closest('[data-filter]');
      if (!btn) return;
      currentFilter = btn.dataset.filter;
      document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      renderTable();
    });

    loadLeads();
    // Auto-refresh every 30 seconds
    setInterval(loadLeads, 30000);
  }
</script>

</body>
</html>
